---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildCanonicalUrl, siteConfig } from '../lib/site';
import { trustPages } from '../lib/trust-pages';

export function getStaticPaths() {
  return trustPages.map((page) => ({
    params: { trustSlug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
const canonicalPath = buildCanonicalUrl(siteConfig.siteUrl, `/${page.slug}/`);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: page.title,
  description: page.description,
  dateModified: page.updated,
  publisher: { '@type': 'Organization', name: siteConfig.siteName },
  url: canonicalPath,
};
---

<BaseLayout
  title={`${page.title} | ${siteConfig.siteName}`}
  description={page.description}
  canonicalPath={canonicalPath}
  siteName={siteConfig.siteName}
  nav={siteConfig.nav}
  metrics={siteConfig.metrics}
  activePath={`/${page.slug}/`}
  schema={schema}
>
  <main id="main-content" class="trust-page">
    <header class="trust-hero">
      <div class="container content-width">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="separator" aria-hidden="true">/</span>
          <span aria-current="page">{page.title}</span>
        </nav>
        <p class="eyebrow-caps kicker--accent">Trust Center</p>
        <h1 class="headline-display">{page.title}</h1>
        <p class="dek dek--large">{page.description}</p>
        <p class="trust-updated">Last updated <time datetime={page.updated}>{page.updated}</time></p>
      </div>
    </header>

    <section class="trust-content">
      <div class="container content-width">
        {page.sections.map((section) => (
          <section class="trust-section">
            <h2 class="headline">{section.heading}</h2>
            <div class="prose">
              {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </section>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .trust-hero {
    padding: var(--space-10) 0 var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }
  .trust-hero .breadcrumbs { margin-bottom: var(--space-4); }
  .trust-hero .eyebrow-caps { margin-top: var(--space-2); }
  .trust-updated {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-2);
  }
  .trust-content { padding: var(--space-10) 0 var(--space-16); }
  .trust-section + .trust-section {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
  .trust-section .prose {
    margin-top: var(--space-4);
  }
  .trust-section p + p { margin-top: var(--space-4); }
</style>
