---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  adsenseReviewPageMap,
  buildCanonicalUrl,
  getAdsenseReviewPageEntries,
  getArticleSchema,
  getFaqSchema,
  getBreadcrumbSchema,
  siteConfig,
} from '../../lib/site';
import { getPrevNext } from '../../lib/articles';
import ComparisonTable from '../../components/ai-tools/ComparisonTable.astro';
import ToolRatingCard from '../../components/ai-tools/ToolRatingCard.astro';
import PricingComparison from '../../components/ai-tools/PricingComparison.astro';
import UseCaseRecommender from '../../components/ai-tools/UseCaseRecommender.astro';
import RelatedComparisons from '../../components/ai-tools/RelatedComparisons.astro';
import ReviewDisclosure from '../../components/editorial/ReviewDisclosure.astro';
import SourceLedger from '../../components/editorial/SourceLedger.astro';
import FactPack from '../../components/editorial/FactPack.astro';
import ConclusionBox from '../../components/editorial/ConclusionBox.astro';
import { getEditorialQualityProfile } from '../../lib/editorial-quality';
import { formatInlineMarkdown } from '../../lib/formatting';
import ReadingProgress from '../../components/common/ReadingProgress.astro';
import Masthead from '../../components/article/Masthead.astro';
import TableOfContents from '../../components/article/TableOfContents.astro';
import PrevNext from '../../components/article/PrevNext.astro';
import ArticleCard from '../../components/cards/ArticleCard.astro';

export function getStaticPaths() {
  return getAdsenseReviewPageEntries().map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const canonicalPath = buildCanonicalUrl(siteConfig.siteUrl, `/pages/${page.slug}/`);
const editorialProfile = getEditorialQualityProfile(page);
const { prev, next } = getPrevNext(page);

const sectionIds = page.sections.map((section, idx) => ({
  id: `section-${idx}`,
  label: section.heading,
}));
if (page.faq.length > 0) sectionIds.push({ id: 'faq', label: 'Frequently asked questions' });

const schemas = [
  getArticleSchema(page),
  ...(page.faq.length > 0 ? [getFaqSchema(page)] : []),
  getBreadcrumbSchema(page, siteConfig.siteUrl),
];

const relatedPages = page.relatedSlugs
  .map((slug) => adsenseReviewPageMap[slug])
  .filter(Boolean);
---

<BaseLayout
  title={`${page.title} | ${siteConfig.siteName}`}
  description={page.description}
  canonicalPath={canonicalPath}
  siteName={siteConfig.siteName}
  nav={siteConfig.nav}
  metrics={siteConfig.metrics}
  activePath={`/pages/${page.slug}/`}
  schema={schemas}
>
  <ReadingProgress target="#article-body" />

  <main id="main-content" class="article-page">
    <Masthead page={page} canonicalUrl={canonicalPath} sourceCount={editorialProfile.sources.length} />

    <div class="article-layout container">
      <TableOfContents items={sectionIds} />

      <article id="article-body" class="article-body">
        <!-- Lead paragraph + intro -->
        <div class="article-intro">
          {page.intro.map((paragraph, idx) => (
            <p class={idx === 0 ? 'prose-lead' : 'prose'}>{paragraph}</p>
          ))}
        </div>

        <ReviewDisclosure profile={editorialProfile} />
        <SourceLedger sources={editorialProfile.sources} />
        <FactPack facts={editorialProfile.factPack} methodology={editorialProfile.methodology} />

        {page.sections.map((section, idx) => (
          <section class="article-section" id={`section-${idx}`}>
            <header class="article-section-header">
              <p class="eyebrow-caps">Section {String(idx + 1).padStart(2, '0')}</p>
              <h2 class="headline-2">{section.heading}</h2>
            </header>

            {section.type === 'paragraphs' && (
              <div class="prose">
                {section.paragraphs.map((paragraph) => (
                  <p set:html={formatInlineMarkdown(paragraph)} />
                ))}
              </div>
            )}

            {section.type === 'bullets' && (
              <ul class="feature-list">
                {section.items.map((item) => (
                  <li>
                    {item.label ? (
                      <><strong>{item.label}:</strong> <span set:html={formatInlineMarkdown(item.text)} /></>
                    ) : (
                      <span set:html={formatInlineMarkdown(item.text)} />
                    )}
                  </li>
                ))}
              </ul>
            )}

            {section.type === 'cards' && (
              <div class="feature-cards">
                {section.cards.map((card) => (
                  <article class="feature-card">
                    <h3>{card.title}</h3>
                    <p set:html={formatInlineMarkdown(card.description)} />
                  </article>
                ))}
              </div>
            )}

            {section.type === 'table' && (
              <div class="table-container">
                <table>
                  <thead>
                    <tr>{section.columns.map((c) => <th>{c}</th>)}</tr>
                  </thead>
                  <tbody>
                    {section.rows.map((row) => (
                      <tr>{row.map((cell) => <td set:html={formatInlineMarkdown(cell)} />)}</tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

            {section.type === 'comparison-table' && (
              <ComparisonTable
                dimensions={section.dimensions}
                tools={section.tools}
                ratings={section.ratings}
              />
            )}

            {section.type === 'tool-cards' && (
              <div class="tool-cards-grid">
                {section.tools.map((tool) => <ToolRatingCard tool={tool} />)}
              </div>
            )}

            {section.type === 'pricing-table' && (
              <PricingComparison plans={section.plans} />
            )}

            {section.type === 'use-case-grid' && (
              <UseCaseRecommender useCases={section.useCases} />
            )}

            {section.type === 'visual-asset' && (
              <figure class="visual-asset-figure" data-visual-kind={section.kind} data-evidence-role={section.evidenceRole}>
                <div class="visual-asset-frame">
                  <img
                    src={section.src}
                    alt={section.alt}
                    loading="lazy"
                    decoding="async"
                    width="1120"
                    height="640"
                  />
                </div>
                <figcaption>
                  <span>{section.evidenceRole === 'evidence' ? 'Evidence visual' : 'Explanatory visual'}</span>
                  {section.caption}
                  {section.credit && <small>{section.credit}</small>}
                </figcaption>
              </figure>
            )}
          </section>
        ))}

        <ConclusionBox conclusion={editorialProfile.conclusion} riskNotes={editorialProfile.riskNotes} />

        {page.faq.length > 0 && (
          <section class="article-section faq" id="faq">
            <header class="article-section-header">
              <p class="eyebrow-caps">Frequently asked</p>
              <h2 class="headline-2">Questions readers ask</h2>
            </header>
            <div class="faq-list">
              {page.faq.map((item) => (
                <details class="faq-item">
                  <summary class="faq-question">{item.question}</summary>
                  <div class="faq-answer">
                    <p set:html={formatInlineMarkdown(item.answer)} />
                  </div>
                </details>
              ))}
            </div>
          </section>
        )}

        <PrevNext prev={prev} next={next} />

        {relatedPages.length > 0 && (
          <section class="related" aria-labelledby="related-heading">
            <header class="article-section-header">
              <p class="eyebrow-caps">Keep reading</p>
              <h2 id="related-heading" class="headline-2">Related analysis</h2>
            </header>
            <div class="related-grid">
              {relatedPages.map((rp) => <ArticleCard page={rp} variant="default" />)}
            </div>
          </section>
        )}

        <RelatedComparisons relatedSlugs={page.relatedSlugs} currentSlug={page.slug} />
      </article>
    </div>
  </main>
</BaseLayout>

<style>
  .article-page { padding-bottom: var(--space-16); }

  .article-layout {
    display: grid;
    gap: var(--space-10);
    padding-top: var(--space-10);
  }

  @media (min-width: 1200px) {
    .article-layout {
      grid-template-columns: 240px minmax(0, 1fr);
    }
  }

  .article-body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .article-intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .article-section {
    scroll-margin-top: calc(var(--header-height) + var(--space-6));
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .article-section:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  .article-section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .article-section-header .eyebrow-caps {
    color: var(--color-primary-light);
  }

  /* ─── Prose styles (inherit .prose utility + local extras) ─── */
  :global(.article-section .prose) {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--prose-leading);
    color: var(--color-text);
  }
  :global(.article-section .prose p) {
    max-width: var(--measure);
  }
  :global(.article-section .prose p + p) {
    margin-top: var(--space-4);
  }

  /* ─── Feature list (bullets) ─── */
  .feature-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
  .feature-list li {
    position: relative;
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-10);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }
  .feature-list li::before {
    content: '';
    position: absolute;
    left: var(--space-4);
    top: calc(var(--space-4) + 6px);
    width: 14px;
    height: 14px;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-success) 22%, transparent);
    border: 1.5px solid var(--color-success);
  }

  /* ─── Feature cards ─── */
  .feature-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .feature-card {
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .feature-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }
  .feature-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ─── Table container ─── */
  .table-container {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }
  .table-container table {
    background: var(--color-surface);
  }

  /* ─── Tool cards grid (3 / 2 / 1 responsive) ─── */
  .tool-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
    align-items: stretch;
  }
  .tool-cards-grid:has(> :nth-child(2):last-child) {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (max-width: 900px) {
    .tool-cards-grid { grid-template-columns: 1fr; }
  }

  /* ─── Growth OS visual assets ─── */
  .visual-asset-figure {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin: 0;
  }

  .visual-asset-frame {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .visual-asset-frame img {
    aspect-ratio: 7 / 4;
    display: block;
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  .visual-asset-figure figcaption {
    color: var(--color-text-muted);
    display: grid;
    font-size: var(--text-sm);
    gap: var(--space-1);
    line-height: var(--leading-normal);
    max-width: var(--measure);
  }

  .visual-asset-figure figcaption span {
    color: var(--color-primary-light);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
  }

  .visual-asset-figure figcaption small {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
  }

  /* ─── FAQ ─── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .faq-item {
    border-left: 3px solid var(--color-accent);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .faq-question {
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-sans);
    font-weight: var(--font-semibold);
    color: var(--color-text-bright);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    transition: transform var(--transition-fast);
  }
  .faq-item[open] .faq-question::after {
    content: '×';
    color: var(--color-primary-light);
  }
  .faq-answer {
    padding: 0 var(--space-5) var(--space-5);
  }
  .faq-answer p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  /* ─── Related grid ─── */
  .related {
    padding-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-5);
  }
</style>
