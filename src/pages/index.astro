---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildCanonicalUrl, estimateSeoPageContentWords, getAdsenseReviewPageEntries, siteConfig } from '../lib/site';
import { trustPages } from '../lib/trust-pages';

const reviewPages = getAdsenseReviewPageEntries();
const canonicalPath = buildCanonicalUrl(siteConfig.siteUrl, '/');
const featuredPages = reviewPages.slice(0, 3);
const comparisonPages = reviewPages.filter((page) => page.category === 'ai-comparison').slice(0, 6);
const guidePages = reviewPages.filter((page) => page.category === 'ai-pillar').slice(0, 6);
---

<BaseLayout
  title={`${siteConfig.siteName} | ${siteConfig.heroTitle}`}
  description={siteConfig.heroDescription}
  canonicalPath={canonicalPath}
  siteName={siteConfig.siteName}
  nav={siteConfig.nav}
  metrics={siteConfig.metrics}
  activePath="/"
>
  <main class="home">
    <section class="home-hero">
      <div class="container home-shell">
        <div class="hero-copy">
          <p class="eyebrow">AI developer tools research</p>
          <h1>{siteConfig.heroTitle}</h1>
          <p class="hero-description">{siteConfig.heroDescription}</p>
          <div class="hero-actions">
            <a class="primary-link" href="/pages/best-ai-coding-tools/">Read the coding tools guide</a>
            <a class="secondary-link" href="/editorial-policy/">Review the editorial policy</a>
          </div>
        </div>
        <aside class="review-panel" aria-label="Current review status">
          <p class="panel-label">Current publishing mode</p>
          <h2>Quality recovery</h2>
          <p>
            The public sitemap is intentionally limited to a small set of stronger source-backed pages while
            SignalForges removes thin content and rebuilds its editorial workflow.
          </p>
          <dl>
            <div>
              <dt>Indexed analysis pages</dt>
              <dd>{reviewPages.length}</dd>
            </div>
            <div>
              <dt>Trust pages</dt>
              <dd>{trustPages.length}</dd>
            </div>
            <div>
              <dt>Minimum article depth</dt>
              <dd>500 words</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="content-band" id="featured">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Selected analysis</p>
          <h2>Start Here</h2>
          <p>These are the highest-confidence pages kept in the AdSense review sitemap.</p>
        </div>
        <div class="feature-grid">
          {featuredPages.map((page) => (
            <a class="article-card article-card-large" href={`/pages/${page.slug}/`}>
              <span>{page.eyebrow}</span>
              <h3>{page.title}</h3>
              <p>{page.description}</p>
              <small>{estimateSeoPageContentWords(page)} words</small>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="content-band muted-band" id="comparisons">
      <div class="container split-section">
        <div class="section-heading compact">
          <p class="eyebrow">Comparisons</p>
          <h2>AI Tool Decisions</h2>
          <p>Side-by-side analysis for readers choosing tools, workflows, and model ecosystems.</p>
        </div>
        <div class="article-list">
          {comparisonPages.map((page) => (
            <a class="article-row" href={`/pages/${page.slug}/`}>
              <div>
                <h3>{page.title}</h3>
                <p>{page.description}</p>
              </div>
              <span>{estimateSeoPageContentWords(page)} words</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="content-band" id="guides">
      <div class="container split-section reverse">
        <div class="section-heading compact">
          <p class="eyebrow">Guides</p>
          <h2>Practical Tool Guides</h2>
          <p>Curated pages with clearer search intent and enough depth to justify indexing.</p>
        </div>
        <div class="article-list">
          {guidePages.map((page) => (
            <a class="article-row" href={`/pages/${page.slug}/`}>
              <div>
                <h3>{page.title}</h3>
                <p>{page.description}</p>
              </div>
              <span>{estimateSeoPageContentWords(page)} words</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="content-band trust-band">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Trust center</p>
          <h2>How SignalForges Is Reviewed</h2>
          <p>These pages document editorial ownership, AI use, privacy, terms, and correction paths.</p>
        </div>
        <div class="trust-grid">
          {trustPages.map((page) => (
            <a class="trust-card" href={`/${page.slug}/`}>
              <h3>{page.title}</h3>
              <p>{page.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home {
    background: var(--color-bg);
  }

  .home-hero {
    border-bottom: 1px solid var(--color-border);
    background:
      linear-gradient(90deg, rgba(20, 184, 166, 0.08), transparent 34%),
      linear-gradient(180deg, var(--color-surface), var(--color-bg));
    padding: var(--space-14) 0;
  }

  .home-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: var(--space-10);
    align-items: center;
  }

  .eyebrow {
    color: #5eead4;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    margin: 0 0 var(--space-3);
    text-transform: uppercase;
  }

  .hero-copy h1 {
    color: var(--color-text-bright);
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    line-height: 1.04;
    margin: 0 0 var(--space-5);
    max-width: 11ch;
  }

  .hero-description {
    color: var(--color-text);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    max-width: 62ch;
    margin: 0 0 var(--space-7);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .primary-link,
  .secondary-link {
    border-radius: var(--radius-md);
    display: inline-flex;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    padding: var(--space-3) var(--space-5);
    text-decoration: none;
  }

  .primary-link {
    background: #14b8a6;
    color: #062b28;
  }

  .secondary-link {
    border: 1px solid var(--color-border);
    color: var(--color-text-bright);
  }

  .review-panel {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .panel-label {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin: 0 0 var(--space-2);
  }

  .review-panel h2 {
    color: var(--color-text-bright);
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-3);
  }

  .review-panel p {
    color: var(--color-text);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-5);
  }

  .review-panel dl {
    display: grid;
    gap: var(--space-3);
    margin: 0;
  }

  .review-panel dl div {
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-3);
  }

  .review-panel dt {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .review-panel dd {
    color: var(--color-text-bright);
    font-weight: var(--font-bold);
    margin: 0;
  }

  .content-band {
    padding: var(--space-12) 0;
  }

  .muted-band {
    background: rgba(15, 23, 42, 0.42);
    border-bottom: 1px solid var(--color-border);
    border-top: 1px solid var(--color-border);
  }

  .trust-band {
    border-top: 1px solid var(--color-border);
  }

  .section-heading {
    margin-bottom: var(--space-7);
    max-width: 720px;
  }

  .section-heading.compact {
    margin-bottom: 0;
  }

  .section-heading h2 {
    color: var(--color-text-bright);
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-3);
  }

  .section-heading p:last-child {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .article-card,
  .trust-card,
  .article-row {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast), transform var(--transition-fast);
  }

  .article-card:hover,
  .trust-card:hover,
  .article-row:hover {
    background: var(--color-card-hover);
    border-color: #14b8a6;
    transform: translateY(-1px);
  }

  .article-card {
    min-height: 280px;
    padding: var(--space-6);
  }

  .article-card span {
    color: #fbbf24;
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-4);
    text-transform: uppercase;
  }

  .article-card h3,
  .trust-card h3,
  .article-row h3 {
    color: var(--color-text-bright);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-3);
  }

  .article-card p,
  .trust-card p,
  .article-row p {
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .article-card small,
  .article-row span {
    color: #5eead4;
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    margin-top: var(--space-5);
    white-space: nowrap;
  }

  .split-section {
    display: grid;
    grid-template-columns: minmax(240px, 0.8fr) minmax(0, 1.2fr);
    gap: var(--space-8);
  }

  .split-section.reverse {
    grid-template-columns: minmax(0, 1.2fr) minmax(240px, 0.8fr);
  }

  .split-section.reverse .section-heading {
    order: 2;
  }

  .article-list {
    display: grid;
    gap: var(--space-3);
  }

  .article-row {
    align-items: flex-start;
    display: flex;
    gap: var(--space-4);
    justify-content: space-between;
    padding: var(--space-5);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .trust-card {
    padding: var(--space-5);
  }

  @media (max-width: 900px) {
    .home-shell,
    .split-section,
    .split-section.reverse,
    .feature-grid,
    .trust-grid {
      grid-template-columns: 1fr;
    }

    .split-section.reverse .section-heading {
      order: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-card,
    .trust-card,
    .article-row {
      transition: none;
    }

    .article-card:hover,
    .trust-card:hover,
    .article-row:hover {
      transform: none;
    }
  }
</style>
