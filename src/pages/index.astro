---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildCanonicalUrl, getAllPageEntries, siteConfig } from '../lib/site';

const pages = getAllPageEntries();
const canonicalPath = buildCanonicalUrl(siteConfig.siteUrl, '/');
---

<BaseLayout
  title={`${siteConfig.siteName} | ${siteConfig.heroTitle}`}
  description={siteConfig.heroDescription}
  canonicalPath={canonicalPath}
  siteName={siteConfig.siteName}
  nav={siteConfig.nav}
  metrics={siteConfig.metrics}
  activePath="/"
>
  <main>
    <section class="hero-section">
      <div class="container hero-grid">
        <div>
          <span class="eyebrow">Deployable Astro SEO starter</span>
          <h1>{siteConfig.heroTitle}</h1>
          <p class="hero-copy">{siteConfig.heroDescription}</p>
          <div class="cta-row">
            <a class="button primary" href={siteConfig.primaryCta.href}>{siteConfig.primaryCta.label}</a>
            <a class="button secondary" href="#page-cluster">View starter cluster</a>
          </div>
        </div>
        <div class="stats-card">
          <h2>Monetization thesis</h2>
          <p>Use evergreen pages to earn informational traffic, then route high-intent visitors toward affiliate pages and future first-party tools.</p>
          <ul>
            {siteConfig.metrics.map((metric) => (
              <li><strong>{metric.value}</strong><span>{metric.label}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">Why this niche</span>
          <h2>Built for SEO + affiliate + future product leverage</h2>
        </div>
        <div class="card-grid three-up">
          {siteConfig.homepageSections.nicheReasons.map((item) => (
            <article class="info-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block alt" id="page-cluster">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">Starter page cluster</span>
          <h2>First scalable batch of deployable pages</h2>
          <p>These thirty-six pages now cover commercial, template, comparison, example, checklist, workflow, governance, sales, agile, generator-intent, tool-intent, role-based, and use-case meeting demand.</p>
        </div>
        <div class="card-grid two-up">
          {pages.map((page) => (
            <article class="page-card">
              <div class="tag-row">
                <span class="tag">{page.category}</span>
                <span class="tag muted">{page.monetizationPrimary}</span>
              </div>
              <h3><a href={`/pages/${page.slug}/`}>{page.title}</a></h3>
              <p>{page.description}</p>
              <p class="small">Target cluster: {page.targetKeyword}</p>
              <a class="text-link" href={`/pages/${page.slug}/`}>Open page →</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow">Monetization map</span>
          <h2>How this site can make money</h2>
        </div>
        <div class="card-grid three-up">
          {siteConfig.homepageSections.monetizationCards.map((card) => (
            <article class="info-card">
              <h3>{card.title}</h3>
              <p>{card.description}</p>
            </article>
          ))}
        </div>
        <div class="callout-banner">
          <strong>Next smart expansion:</strong> add downloadable template packs, interactive generators, and more vendor-specific comparison pages to compound affiliate and product revenue.
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
