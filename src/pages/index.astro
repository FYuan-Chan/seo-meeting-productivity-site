---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildCanonicalUrl, siteConfig } from '../lib/site';
import { trustPages } from '../lib/trust-pages';
import {
  getAllPublishedArticles,
  groupByCategory,
  sortByUpdated,
} from '../lib/articles';
import HeroLead from '../components/home/HeroLead.astro';
import LatestGrid from '../components/home/LatestGrid.astro';
import CategoryRail from '../components/home/CategoryRail.astro';

const all = sortByUpdated(getAllPublishedArticles());
const byCategory = groupByCategory(all);
const lead = all[0];
const secondary = all.slice(1, 3);
const latest = all.slice(3, 12);

const canonicalPath = buildCanonicalUrl(siteConfig.siteUrl, '/');

const rails: { category: keyof typeof byCategory; title: string; description: string }[] = [
  {
    category: 'ai-comparison',
    title: 'Head-to-head comparisons',
    description: 'Pick the right coding assistant, model platform, or agent runtime before you commit to a trial.',
  },
  {
    category: 'ai-pillar',
    title: 'Deep dives on the AI landscape',
    description: 'Long-form analysis of ecosystems, model releases, and the infrastructure shifts that matter.',
  },
];
---

<BaseLayout
  title={`${siteConfig.siteName} — ${siteConfig.niche}`}
  description={siteConfig.heroDescription}
  canonicalPath={canonicalPath}
  siteName={siteConfig.siteName}
  nav={siteConfig.nav}
  metrics={siteConfig.metrics}
  activePath="/"
>
  <main id="main-content" class="home">
    {lead && secondary.length > 0 && (
      <HeroLead lead={lead} secondary={secondary} />
    )}

    {latest.length > 0 && (
      <LatestGrid items={latest} />
    )}

    {rails.map((rail) => {
      const items = byCategory[rail.category] ?? [];
      if (items.length < 3) return null;
      return (
        <CategoryRail
          category={rail.category}
          title={rail.title}
          description={rail.description}
          items={sortByUpdated(items)}
        />
      );
    })}

    <section class="trust" aria-labelledby="trust-heading">
      <div class="container">
        <header class="trust-header">
          <p class="eyebrow-caps">Trust Center</p>
          <h2 id="trust-heading" class="headline-2">How SignalForges is reviewed</h2>
          <p class="trust-dek">
            Editorial policy, AI use disclosure, privacy, terms, and correction paths live in one place so readers know what to expect.
          </p>
        </header>
        <div class="trust-grid">
          {trustPages.map((page) => (
            <a class="trust-card" href={`/${page.slug}/`}>
              <h3 class="headline-sans">{page.title}</h3>
              <p>{page.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home {
    min-height: 100vh;
  }

  /* ─── Trust section (low-emphasis) ─── */
  .trust {
    padding: var(--space-12) 0;
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
  }
  .trust-header { max-width: 60ch; margin-bottom: var(--space-6); }
  .trust-dek {
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .trust-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    text-decoration: none;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }
  .trust-card:hover {
    border-color: var(--color-border-hover);
    background: var(--color-surface-hover);
  }
  .trust-card h3 { font-size: var(--text-base); }
  .trust-card p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0;
  }
</style>
