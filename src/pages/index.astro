---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildCanonicalUrl, getAllPageEntries, siteConfig } from '../lib/site';

const pages = getAllPageEntries();
const aiToolPages = getAllPageEntries().filter(p => 
  p.category.startsWith('ai-') || p.category === 'github-trending' || p.category === 'tutorial'
);
const meetingPages = getAllPageEntries().filter(p => 
  p.category.startsWith('meeting') || p.category === 'template' || p.category === 'comparison'
);
const canonicalPath = buildCanonicalUrl(siteConfig.siteUrl, '/');

// Featured articles: latest briefing + related articles
const briefingPages = aiToolPages.filter(p => p.slug.startsWith('ai-briefing-')).sort((a, b) => b.slug.localeCompare(a.slug));
const latestBriefing = briefingPages[0];

let featuredPages = [];
if (latestBriefing) {
  // Get related pages from the briefing
  const relatedSlugs = latestBriefing.relatedSlugs || [];
  const relatedPages = relatedSlugs.map(slug => aiToolPages.find(p => p.slug === slug)).filter(Boolean);
  
  // Combine: briefing first, then related pages (up to 3 total)
  featuredPages = [latestBriefing, ...relatedPages.slice(0, 2)];
} else {
  // Fallback: first 3 AI tool pages
  featuredPages = aiToolPages.slice(0, 3);
}

// Latest articles (last 6 pages, excluding featured)
const latestPages = pages.filter(p => !featuredPages.includes(p)).slice(-6).reverse();
---

<BaseLayout
  title={`${siteConfig.siteName} | ${siteConfig.heroTitle}`}
  description={siteConfig.heroDescription}
  canonicalPath={canonicalPath}
  siteName={siteConfig.siteName}
  nav={siteConfig.nav}
  metrics={siteConfig.metrics}
  activePath="/"
>
  <main class="homepage">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <span class="hero-badge">🚀 AI Tools & Productivity</span>
          <h1 class="hero-title">
            <span class="gradient-text">AI tool comparisons</span> and productivity guides for modern teams
          </h1>
          <p class="hero-description">
            In-depth reviews, real usage data, and side-by-side comparisons to help you choose the right AI tools.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="#featured">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
              </svg>
              Explore Featured
            </a>
            <a class="btn btn-secondary btn-lg" href="#latest">
              Latest Articles
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </div>
        
        <!-- Stats -->
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">{pages.length}</span>
            <span class="stat-label">Total Pages</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">{aiToolPages.length}</span>
            <span class="stat-label">AI Tool Reviews</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">{meetingPages.length}</span>
            <span class="stat-label">Meeting Guides</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Category Navigation -->
    <section class="categories">
      <div class="container">
        <nav class="category-nav">
          <a href="#ai-tools" class="category-pill active">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2a10 10 0 1 0 10 10H12V2z"></path>
              <path d="M12 2a10 10 0 0 1 10 10"></path>
              <circle cx="12" cy="12" r="6"></circle>
            </svg>
            AI Tools
          </a>
          <a href="#meetings" class="category-pill">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            Meetings
          </a>
          <a href="#templates" class="category-pill">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
            Templates
          </a>
          <a href="#comparisons" class="category-pill">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="20" x2="18" y2="10"></line>
              <line x1="12" y1="20" x2="12" y2="4"></line>
              <line x1="6" y1="20" x2="6" y2="14"></line>
            </svg>
            Comparisons
          </a>
        </nav>
      </div>
    </section>

    <!-- Featured Articles -->
    <section class="featured-section" id="featured">
      <div class="container">
        <div class="section-header">
          <div>
            <span class="section-badge">⭐ Featured</span>
            <h2 class="section-title">Editor's Picks</h2>
            <p class="section-subtitle">Our most comprehensive guides and comparisons</p>
          </div>
          <a href="#ai-tools" class="view-all">
            View all articles
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
        
        <div class="featured-grid">
          {featuredPages.map((page, idx) => (
            <a href={`/pages/${page.slug}/`} class={`featured-card ${idx === 0 ? 'featured-main' : ''}`}>
              <div class="card-image">
                <span class="card-category">{page.eyebrow}</span>
              </div>
              <div class="card-content">
                <h3 class="card-title">{page.title}</h3>
                <p class="card-description">{page.description}</p>
                <div class="card-meta">
                  <span class="meta-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    5 min read
                  </span>
                  <span class="meta-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                      <line x1="7" y1="7" x2="7.01" y2="7"></line>
                    </svg>
                    {page.category}
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Latest Articles -->
    <section class="latest-section" id="latest">
      <div class="container">
        <div class="section-header">
          <div>
            <span class="section-badge">📰 Latest</span>
            <h2 class="section-title">Recent Articles</h2>
            <p class="section-subtitle">Fresh content added regularly</p>
          </div>
        </div>
        
        <div class="latest-grid">
          {latestPages.map((page) => (
            <a href={`/pages/${page.slug}/`} class="latest-card">
              <div class="card-header">
                <span class="card-category">{page.category}</span>
                <span class="card-time">4 min read</span>
              </div>
              <h3 class="card-title">{page.title}</h3>
              <p class="card-description">{page.description.slice(0, 100)}...</p>
              <div class="card-footer">
                <span class="read-more">
                  Read article
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- AI Tools Section -->
    <section class="ai-tools-section" id="ai-tools">
      <div class="container">
        <div class="section-header">
          <div>
            <span class="section-badge">🤖 AI Tools</span>
            <h2 class="section-title">AI Tools & Comparisons</h2>
            <p class="section-subtitle">In-depth reviews and side-by-side comparisons</p>
          </div>
          <a href="/pages/best-ai-coding-tools/" class="view-all">
            View all AI tools
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
        
        <div class="tools-grid">
          {aiToolPages.map((page) => (
            <a href={`/pages/${page.slug}/`} class="tool-card">
              <div class="tool-icon">
                {page.slug.includes('chatgpt') && '💬'}
                {page.slug.includes('claude') && '🤖'}
                {page.slug.includes('copilot') && '👨‍💻'}
                {page.slug.includes('cursor') && '🖱️'}
                {page.slug.includes('midjourney') && '🎨'}
                {page.slug.includes('dalle') && '🖼️'}
                {page.slug.includes('grammarly') && '✍️'}
                {page.slug.includes('notion') && '📝'}
                {page.slug.includes('jasper') || page.slug.includes('copy') && '📄'}
                {!page.slug.includes('chatgpt') && !page.slug.includes('claude') && !page.slug.includes('copilot') && 
                 !page.slug.includes('cursor') && !page.slug.includes('midjourney') && !page.slug.includes('dalle') &&
                 !page.slug.includes('grammarly') && !page.slug.includes('notion') && !page.slug.includes('jasper') && 
                 !page.slug.includes('copy') && '🔧'}
              </div>
              <div class="tool-content">
                <span class="tool-category">{page.eyebrow}</span>
                <h3 class="tool-title">{page.title}</h3>
                <p class="tool-description">{page.description.slice(0, 80)}...</p>
              </div>
              <div class="tool-arrow">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Meeting Templates Section -->
    <section class="meetings-section" id="meetings">
      <div class="container">
        <div class="section-header">
          <div>
            <span class="section-badge">📅 Meetings</span>
            <h2 class="section-title">Meeting Templates & Guides</h2>
            <p class="section-subtitle">Templates, checklists, and best practices</p>
          </div>
          <a href="/pages/meeting-notes-template/" class="view-all">
            View all templates
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
        
        <div class="meetings-grid">
          {meetingPages.slice(0, 6).map((page) => (
            <a href={`/pages/${page.slug}/`} class="meeting-card">
              <span class="meeting-type">{page.category}</span>
              <h3 class="meeting-title">{page.title}</h3>
              <p class="meeting-description">{page.description.slice(0, 100)}...</p>
              <span class="meeting-link">
                Open template
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="newsletter-section">
      <div class="container">
        <div class="newsletter-card">
          <div class="newsletter-content">
            <span class="newsletter-badge">📬 Stay Updated</span>
            <h2>Get the latest AI tool reviews & meeting templates</h2>
            <p>Join 5,000+ professionals who receive weekly insights on AI productivity tools and meeting best practices.</p>
          </div>
          <form class="newsletter-form">
            <input type="email" placeholder="Enter your email" class="newsletter-input" />
            <button type="submit" class="btn btn-primary">Subscribe</button>
          </form>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ─── Homepage Layout ─── */
  .homepage {
    min-height: 100vh;
  }

  /* ─── Hero Section ─── */
  .hero {
    padding: var(--space-16) 0 var(--space-12);
    background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-bg) 100%);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(ellipse at 20% 50%, rgba(59, 130, 246, 0.1) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(139, 92, 246, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-content {
    max-width: 800px;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: var(--radius-full);
    color: var(--color-primary-light);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-6);
  }

  .hero-title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: var(--font-extrabold);
    line-height: var(--leading-tight);
    color: var(--color-text-bright);
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-accent-light));
    -webkit-background-clip: text;
    background-clip: text;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 60ch;
    margin-bottom: var(--space-8);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    gap: var(--space-8);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    position: relative;
    z-index: 1;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat-number {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-primary-light);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ─── Buttons ─── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    font-weight: var(--font-semibold);
    font-size: var(--text-sm);
    border-radius: var(--radius-lg);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all var(--transition-base);
    text-decoration: none;
  }

  .btn-lg {
    padding: var(--space-4) var(--space-6);
    font-size: var(--text-base);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    box-shadow: var(--shadow-md);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
    color: white;
  }

  .btn-secondary {
    background: var(--color-surface);
    border-color: var(--color-border);
    color: var(--color-text);
  }

  .btn-secondary:hover {
    background: var(--color-surface-hover);
    border-color: var(--color-border-hover);
    color: var(--color-text-bright);
  }

  /* ─── Category Navigation ─── */
  .categories {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 60px;
    z-index: var(--z-sticky);
  }

  .category-nav {
    display: flex;
    gap: var(--space-3);
    overflow-x: auto;
    padding-bottom: var(--space-2);
    -webkit-overflow-scrolling: touch;
  }

  .category-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    white-space: nowrap;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .category-pill:hover,
  .category-pill.active {
    background: rgba(59, 130, 246, 0.1);
    border-color: rgba(59, 130, 246, 0.3);
    color: var(--color-primary-light);
  }

  .category-pill.active {
    background: rgba(59, 130, 246, 0.15);
    border-color: var(--color-primary);
  }

  /* ─── Section Styles ─── */
  .featured-section,
  .latest-section,
  .ai-tools-section,
  .meetings-section {
    padding: var(--space-12) 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-8);
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .section-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: var(--radius-full);
    color: var(--color-accent-light);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-text-bright);
    margin-bottom: var(--space-2);
  }

  .section-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0;
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary-light);
    font-weight: var(--font-semibold);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .view-all:hover {
    color: var(--color-primary);
    gap: var(--space-3);
  }

  /* ─── Featured Grid ─── */
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .featured-card {
    display: flex;
    flex-direction: column;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .featured-card:hover {
    background: var(--color-card-hover);
    border-color: var(--color-border-hover);
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
  }

  .featured-main {
    grid-column: span 2;
  }

  .card-image {
    height: 200px;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-card) 100%);
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: var(--space-4);
  }

  .featured-main .card-image {
    height: 280px;
  }

  .card-category {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: rgba(59, 130, 246, 0.2);
    border-radius: var(--radius-full);
    color: var(--color-primary-light);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-content {
    padding: var(--space-5);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-text-bright);
    margin-bottom: var(--space-3);
    line-height: var(--leading-snug);
  }

  .featured-main .card-title {
    font-size: var(--text-2xl);
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    flex: 1;
    margin-bottom: var(--space-4);
  }

  .card-meta {
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  /* ─── Latest Grid ─── */
  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .latest-card {
    display: flex;
    flex-direction: column;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .latest-card:hover {
    background: var(--color-card-hover);
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
