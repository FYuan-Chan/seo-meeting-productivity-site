---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildCanonicalUrl, siteConfig } from '../lib/site';

const canonicalPath = buildCanonicalUrl(siteConfig.siteUrl, '/404.html');
---

<BaseLayout
  title={`Page Not Found | ${siteConfig.siteName}`}
  description="This SignalForges page is not available in the current public index."
  canonicalPath={canonicalPath}
  siteName={siteConfig.siteName}
  nav={siteConfig.nav}
  metrics={siteConfig.metrics}
  activePath="/404.html"
  noindex={true}
>
  <main id="main-content" class="not-found">
    <div class="container content-width nf-shell">
      <p class="eyebrow-caps kicker--accent">404</p>
      <h1 class="headline-display">Page not found.</h1>
      <p class="dek dek--large">
        This URL is not part of the current SignalForges public index. Thin drafts, experimental
        pages, and duplicates stay out of navigation until they meet the editorial bar.
      </p>
      <div class="nf-actions">
        <a class="btn btn-primary" href="/">Go home</a>
        <a class="btn btn-secondary" href="/archive/">Browse all articles</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    padding: var(--space-16) 0;
  }
  .nf-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
</style>
