---
/**
 * SearchDialog
 * ⌘K / Ctrl+K opens a client-side search over the public article whitelist.
 * Index is fetched lazily from /search.json on first open.
 * Falls back to /archive/ when JS is disabled — the trigger button is in the header.
 */
---

<dialog id="search-dialog" class="search-dialog" data-search-dialog aria-labelledby="search-dialog-title">
  <form method="dialog" class="search-backdrop" aria-hidden="true">
    <button type="submit" aria-label="Close search"></button>
  </form>

  <div class="search-panel" role="document">
    <div class="search-header">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="M21 21l-4.3-4.3"></path>
      </svg>
      <label for="search-input" class="visually-hidden" id="search-dialog-title">Search articles</label>
      <input
        id="search-input"
        type="search"
        autocomplete="off"
        placeholder="Search articles, comparisons, guides…"
        data-search-input
      />
      <kbd class="search-hint">Esc</kbd>
    </div>

    <div class="search-results" data-search-results role="listbox" aria-label="Search results">
      <p class="search-empty" data-search-empty>Start typing to search published articles.</p>
    </div>

    <p class="search-footer">
      <span>↑↓ navigate · ↵ open · Esc close</span>
      <a href="/archive/">Browse all →</a>
    </p>
  </div>
</dialog>

<script>
  type SearchItem = {
    slug: string;
    title: string;
    description: string;
    eyebrow: string;
    category: string;
  };

  const dialog = document.querySelector<HTMLDialogElement>('[data-search-dialog]');
  const input = document.querySelector<HTMLInputElement>('[data-search-input]');
  const resultsEl = document.querySelector<HTMLElement>('[data-search-results]');
  const emptyEl = document.querySelector<HTMLElement>('[data-search-empty]');
  const trigger = document.querySelector<HTMLButtonElement>('[data-search-open]');

  let index: SearchItem[] = [];
  let indexLoaded = false;
  let activeIdx = -1;

  function openDialog() {
    if (!dialog) return;
    if (typeof dialog.showModal === 'function') {
      dialog.showModal();
    } else {
      dialog.setAttribute('open', '');
    }
    loadIndex();
    setTimeout(() => input?.focus(), 20);
  }

  function closeDialog() {
    if (!dialog) return;
    if (dialog.open) dialog.close();
  }

  async function loadIndex() {
    if (indexLoaded) return;
    indexLoaded = true;
    try {
      const res = await fetch('/search.json');
      if (res.ok) index = await res.json();
    } catch {
      indexLoaded = false;
    }
  }

  function score(item: SearchItem, q: string): number {
    const query = q.toLowerCase();
    const title = item.title.toLowerCase();
    const desc = item.description.toLowerCase();
    let s = 0;
    if (title.startsWith(query)) s += 6;
    if (title.includes(query)) s += 3;
    if (desc.includes(query)) s += 1;
    if (item.slug.includes(query)) s += 2;
    return s;
  }

  function render(q: string) {
    if (!resultsEl || !emptyEl) return;
    const query = q.trim();
    if (!query) {
      resultsEl.innerHTML = '';
      resultsEl.appendChild(emptyEl);
      emptyEl.textContent = 'Start typing to search published articles.';
      activeIdx = -1;
      return;
    }
    const matches = index
      .map((item) => ({ item, s: score(item, query) }))
      .filter(({ s }) => s > 0)
      .sort((a, b) => b.s - a.s)
      .slice(0, 10)
      .map(({ item }) => item);

    if (matches.length === 0) {
      resultsEl.innerHTML = '';
      resultsEl.appendChild(emptyEl);
      emptyEl.textContent = `No matches for "${query}".`;
      activeIdx = -1;
      return;
    }

    activeIdx = 0;
    resultsEl.textContent = '';
    matches.forEach((m, i) => {
      const a = document.createElement('a');
      a.className = 'search-result';
      a.setAttribute('role', 'option');
      a.setAttribute('href', '/pages/' + m.slug + '/');
      a.setAttribute('data-idx', String(i));
      a.setAttribute('aria-selected', i === 0 ? 'true' : 'false');

      const eyebrow = document.createElement('span');
      eyebrow.className = 'search-result-eyebrow';
      eyebrow.textContent = m.eyebrow;

      const title = document.createElement('span');
      title.className = 'search-result-title';
      title.textContent = m.title;

      const desc = document.createElement('span');
      desc.className = 'search-result-desc';
      desc.textContent = m.description;

      a.appendChild(eyebrow);
      a.appendChild(title);
      a.appendChild(desc);
      resultsEl.appendChild(a);
    });
  }

  function move(delta: number) {
    if (!resultsEl) return;
    const items = resultsEl.querySelectorAll<HTMLAnchorElement>('.search-result');
    if (items.length === 0) return;
    activeIdx = (activeIdx + delta + items.length) % items.length;
    items.forEach((el, i) => el.setAttribute('aria-selected', i === activeIdx ? 'true' : 'false'));
    items[activeIdx]?.scrollIntoView({ block: 'nearest' });
  }

  function openActive() {
    if (!resultsEl) return;
    const items = resultsEl.querySelectorAll<HTMLAnchorElement>('.search-result');
    if (items[activeIdx]) window.location.href = items[activeIdx].href;
  }

  trigger?.addEventListener('click', openDialog);

  window.addEventListener('keydown', (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      openDialog();
    } else if (e.key === 'Escape' && dialog?.open) {
      closeDialog();
    }
  });

  input?.addEventListener('input', (e) => render((e.target as HTMLInputElement).value));
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
    else if (e.key === 'Enter') { e.preventDefault(); openActive(); }
  });
</script>

<style>
  .search-dialog {
    padding: 0;
    border: 0;
    background: transparent;
    max-width: 680px;
    width: calc(100% - 2rem);
    max-height: 80vh;
    margin: 10vh auto;
    color: var(--color-text);
  }
  .search-dialog::backdrop {
    background: color-mix(in srgb, var(--color-bg-deepest) 78%, transparent);
    backdrop-filter: blur(6px);
  }
  .search-backdrop { display: none; }

  .search-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--elevation-3);
    overflow: hidden;
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }
  .search-icon { color: var(--color-text-muted); flex: 0 0 auto; }
  #search-input {
    flex: 1;
    background: transparent;
    border: 0;
    color: var(--color-text-bright);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    outline: none;
  }
  .search-hint {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    padding: 2px 6px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .search-results {
    max-height: 60vh;
    overflow-y: auto;
    padding: var(--space-2);
  }
  .search-empty {
    padding: var(--space-6);
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  :global(.search-result) {
    display: grid;
    gap: 2px;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: background-color var(--transition-fast);
  }
  :global(.search-result:hover),
  :global(.search-result[aria-selected='true']) {
    background: var(--color-surface-hover);
  }
  :global(.search-result-eyebrow) {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  :global(.search-result-title) {
    font-family: var(--font-sans);
    font-weight: var(--font-semibold);
    color: var(--color-text-bright);
  }
  :global(.search-result-desc) {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .search-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-5);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
  }
  .search-footer a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .search-footer a:hover { color: var(--color-text-bright); }
</style>
