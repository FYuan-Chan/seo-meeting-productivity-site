---
import ThemeToggle from './ThemeToggle.astro';

interface NavItem { label: string; href: string; }
interface Props {
  siteName?: string;
  nav?: NavItem[];
  activePath?: string;
}

const { siteName = 'SignalForges', nav = [], activePath = '/' } = Astro.props;

function isActive(href: string) {
  if (href === activePath) return true;
  if (href === '/') return activePath === '/';
  return activePath.startsWith(href);
}
---

<header class="site-header" data-site-header>
  <div class="container header-shell">
    <a class="brand" href="/" aria-label={`${siteName} home`}>
      <span class="brand-mark" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 18l6-12 4 8 3-5 5 9" />
        </svg>
      </span>
      <span class="brand-word">{siteName}</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={{ 'nav-link': true, active: isActive(item.href) }}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <button
        type="button"
        class="search-trigger"
        data-search-open
        aria-haspopup="dialog"
        aria-controls="search-dialog"
        aria-label="Open search"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M21 21l-4.3-4.3"></path>
        </svg>
        <span class="search-trigger-label">Search</span>
        <kbd class="search-trigger-kbd">⌘K</kbd>
      </button>
      <ThemeToggle />
    </div>

    <details class="mobile-menu">
      <summary aria-label="Open menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18"></path>
        </svg>
      </summary>
      <div class="mobile-panel">
        <nav aria-label="Mobile primary">
          {nav.map((item) => (
            <a href={item.href} class:list={{ active: isActive(item.href) }}>{item.label}</a>
          ))}
        </nav>
        <div class="mobile-extras">
          <a href="/archive/">All articles</a>
          <a href="/editorial-policy/">Editorial Policy</a>
        </div>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    border-bottom: 1px solid var(--color-border);
  }

  .header-shell {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-6);
    height: var(--header-height);
  }

  /* ─── Brand ─── */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-weight: var(--font-bold);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-bright);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }
  .brand:hover { opacity: 0.85; color: var(--color-text-bright); }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #fff;
  }
  .brand-word { line-height: 1; }

  /* ─── Primary nav ─── */
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    font-family: var(--font-sans);
  }
  .nav-link {
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text-bright);
    background: var(--color-surface-hover);
  }
  .nav-link.active {
    color: var(--color-primary-light);
  }

  /* ─── Actions (search + theme) ─── */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 36px;
    padding: 0 var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .search-trigger:hover {
    color: var(--color-text-bright);
    border-color: var(--color-border-hover);
    background: var(--color-surface-hover);
  }
  .search-trigger-label { line-height: 1; }
  .search-trigger-kbd {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    padding: 2px 6px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-dim);
    background: var(--color-bg-alt);
  }

  /* ─── Mobile menu ─── */
  .mobile-menu { display: none; position: relative; }
  .mobile-menu > summary {
    list-style: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    cursor: pointer;
  }
  .mobile-menu > summary::-webkit-details-marker { display: none; }
  .mobile-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    min-width: 240px;
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--elevation-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .mobile-panel nav,
  .mobile-panel .mobile-extras {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .mobile-panel .mobile-extras {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-2);
    margin-top: var(--space-1);
  }
  .mobile-panel a {
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text);
    border-radius: var(--radius-md);
    text-decoration: none;
  }
  .mobile-panel a:hover,
  .mobile-panel a.active {
    color: var(--color-text-bright);
    background: var(--color-surface-hover);
  }

  @media (max-width: 960px) {
    .search-trigger-label { display: none; }
    .search-trigger-kbd { display: none; }
  }

  @media (max-width: 768px) {
    .header-shell {
      grid-template-columns: 1fr auto auto;
      gap: var(--space-3);
    }
    .site-nav { display: none; }
    .mobile-menu { display: inline-block; }
  }
</style>
