---
/**
 * ThemeToggle
 * - Inline init script (set early in BaseLayout <head>) prevents FOUC.
 * - This component renders the toggle button and wires the click handler.
 */
---

<button
  type="button"
  class="theme-toggle"
  aria-label="Toggle color theme"
  data-theme-toggle
>
  <svg class="theme-icon theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
  </svg>
  <svg class="theme-icon theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    var btn = document.querySelector('[data-theme-toggle]');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var current = document.documentElement.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try {
        localStorage.setItem('signalforges-theme', next);
      } catch (e) { /* ignore */ }
    });
  })();
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .theme-toggle:hover {
    color: var(--color-text-bright);
    border-color: var(--color-border-hover);
    background: var(--color-surface-hover);
  }

  .theme-icon {
    position: absolute;
    transition: opacity var(--transition-fast), transform var(--transition-base);
  }

  html[data-theme='dark'] .theme-icon--sun { opacity: 1; transform: rotate(0); }
  html[data-theme='dark'] .theme-icon--moon { opacity: 0; transform: rotate(-90deg); }

  html[data-theme='light'] .theme-icon--sun { opacity: 0; transform: rotate(90deg); }
  html[data-theme='light'] .theme-icon--moon { opacity: 1; transform: rotate(0); }
</style>
