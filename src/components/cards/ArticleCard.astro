---
import type { SeoPage } from '../../lib/site';
import { estimateReadingTime, formatUpdated } from '../../lib/articles';

type Variant = 'hero' | 'featured' | 'default' | 'compact' | 'row';

interface Props {
  page: SeoPage;
  variant?: Variant;
  showDek?: boolean;
  showEyebrow?: boolean;
  showMeta?: boolean;
}

const {
  page,
  variant = 'default',
  showDek,
  showEyebrow = true,
  showMeta = true,
} = Astro.props;

const dekVisible = showDek ?? (variant !== 'compact' && variant !== 'row');
const readingTime = estimateReadingTime(page);
const updated = formatUpdated(page);
const href = `/pages/${page.slug}/`;
---

<a class:list={['article-card', `article-card--${variant}`]} data-variant={variant} href={href}>
  {showEyebrow && <span class="eyebrow-caps article-card-eyebrow">{page.eyebrow}</span>}
  <h3 class="article-card-title">{page.title}</h3>
  {dekVisible && <p class="article-card-dek">{page.description}</p>}
  {showMeta && (
    <p class="article-card-meta">
      <span>{readingTime} min read</span>
      {updated && <><span aria-hidden="true">·</span><span>{updated}</span></>}
    </p>
  )}
</a>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    color: inherit;
    text-decoration: none;
    transition: border-color var(--transition-base), transform var(--transition-base), box-shadow var(--transition-base), background-color var(--transition-base);
    height: 100%;
  }

  .article-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-1px);
    box-shadow: var(--elevation-2);
    background: var(--color-card-hover);
  }

  .article-card-eyebrow {
    color: var(--color-primary-light);
  }

  .article-card-title {
    font-family: var(--font-sans);
    font-weight: var(--font-semibold);
    color: var(--color-text-bright);
    line-height: 1.25;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
    font-size: var(--text-xl);
    /* clamp 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card-dek {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
    margin-top: auto;
  }

  /* ─── Hero variant ─── */
  .article-card--hero {
    padding: var(--space-8);
    gap: var(--space-4);
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, var(--color-surface), color-mix(in srgb, var(--color-primary) 6%, var(--color-surface)));
  }
  .article-card--hero .article-card-title {
    font-family: var(--font-display);
    font-weight: var(--font-bold);
    font-size: var(--text-display-2);
    line-height: 1.08;
    letter-spacing: var(--tracking-tight);
    -webkit-line-clamp: 3;
  }
  .article-card--hero .article-card-dek {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    -webkit-line-clamp: 3;
  }

  /* ─── Featured ─── */
  .article-card--featured .article-card-title {
    font-family: var(--font-display);
    font-weight: var(--font-semibold);
    font-size: var(--text-headline);
    line-height: 1.15;
    -webkit-line-clamp: 3;
  }
  .article-card--featured .article-card-dek {
    -webkit-line-clamp: 2;
  }

  /* ─── Compact (rails) ─── */
  .article-card--compact {
    padding: var(--space-4);
    gap: var(--space-2);
  }
  .article-card--compact .article-card-title {
    font-size: var(--text-base);
    -webkit-line-clamp: 3;
  }

  /* ─── Row (archive / list) ─── */
  .article-card--row {
    flex-direction: row;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-md);
    background: transparent;
    border-top: 1px solid var(--color-border);
    border-left: 0;
    border-right: 0;
    border-bottom: 0;
    height: auto;
  }
  .article-card--row:hover {
    background: var(--color-surface-hover);
    border-color: var(--color-border);
    transform: none;
    box-shadow: none;
  }
  .article-card--row .article-card-title {
    font-family: var(--font-sans);
    font-weight: var(--font-medium);
    font-size: var(--text-base);
    -webkit-line-clamp: 2;
    line-height: 1.4;
  }
  .article-card--row .article-card-meta {
    margin: 0;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .article-card--hero {
      padding: var(--space-6);
    }
    .article-card--hero .article-card-title {
      font-size: var(--text-3xl);
    }
    .article-card--row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
