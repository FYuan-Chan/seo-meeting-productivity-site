---
import type { SeoPage } from '../../lib/site';

interface Props {
  prev?: SeoPage;
  next?: SeoPage;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="prevnext" aria-label="Previous and next articles">
    {prev ? (
      <a class="prevnext-link prevnext-prev" href={`/pages/${prev.slug}/`}>
        <span class="prevnext-eyebrow">← Previous</span>
        <span class="prevnext-title">{prev.title}</span>
      </a>
    ) : <span />}
    {next ? (
      <a class="prevnext-link prevnext-next" href={`/pages/${next.slug}/`}>
        <span class="prevnext-eyebrow">Next →</span>
        <span class="prevnext-title">{next.title}</span>
      </a>
    ) : <span />}
  </nav>
)}

<style>
  .prevnext {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin: var(--space-10) 0;
  }
  .prevnext-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: inherit;
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .prevnext-link:hover {
    border-color: var(--color-border-hover);
    background: var(--color-surface-hover);
  }
  .prevnext-next { text-align: right; }
  .prevnext-eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
  }
  .prevnext-title {
    font-family: var(--font-sans);
    font-weight: var(--font-semibold);
    color: var(--color-text-bright);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .prevnext { grid-template-columns: 1fr; }
    .prevnext-next { text-align: left; }
  }
</style>
