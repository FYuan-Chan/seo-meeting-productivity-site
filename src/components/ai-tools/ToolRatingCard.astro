---
import type { ToolCardData } from '../../lib/site';
import { appendUtmParams } from '../../lib/site';

interface Props {
  tool: ToolCardData;
}

const { tool } = Astro.props;
const ctaUrlWithUtm = appendUtmParams(tool.ctaUrl);

const fullStars = Math.floor(tool.rating);
const partialFill = Math.round((tool.rating - fullStars) * 100);
const emptyStars = 5 - fullStars - (partialFill > 0 ? 1 : 0);

const initial = tool.name.charAt(0).toUpperCase();
---

<div class="tool-rating-card">
  <div class="card-top">
    {tool.logo ? (
      <img src={tool.logo} alt={`${tool.name} logo`} class="tool-logo" width="64" height="64" />
    ) : (
      <div class="tool-logo-placeholder" aria-hidden="true">{initial}</div>
    )}
    <div class="card-top-info">
      <h3 class="tool-name">{tool.name}</h3>
      <div class="star-rating" aria-label={`Rating: ${tool.rating} out of 5`}>
        {Array.from({ length: fullStars }).map(() => (
          <span class="star full">&#9733;</span>
        ))}
        {partialFill > 0 && (
          <span
            class="star partial"
            style={`--fill: ${partialFill}%`}
          >&#9733;</span>
        )}
        {Array.from({ length: emptyStars }).map(() => (
          <span class="star empty">&#9733;</span>
        ))}
        <span class="rating-value">{tool.rating.toFixed(1)}</span>
      </div>
    </div>
  </div>

  <p class="tool-summary">{tool.summary}</p>

  {tool.pros.length > 0 && (
    <ul class="pros-list">
      {tool.pros.map((pro) => (
        <li><span class="icon pro-icon" aria-hidden="true">&#10003;</span>{pro}</li>
      ))}
    </ul>
  )}

  {tool.cons.length > 0 && (
    <ul class="cons-list">
      {tool.cons.map((con) => (
        <li><span class="icon con-icon" aria-hidden="true">&#10007;</span>{con}</li>
      ))}
    </ul>
  )}

  <div class="card-bottom">
    {tool.pricing && (
      <span class="pricing-tag">{tool.pricing}</span>
    )}
    <a
      href={ctaUrlWithUtm}
      class="cta-btn"
      target="_blank"
      rel="nofollow sponsored noopener"
    >
      {tool.ctaLabel}
    </a>
  </div>
</div>

<style>
  .tool-rating-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: var(--space-3);
    transition: all var(--transition-base);
  }

  .tool-rating-card:hover {
    background: var(--color-card-hover);
    border-color: var(--color-border-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-lg);
  }

  .tool-rating-card:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  /* Top: logo + name + stars */
  .card-top {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-height: 64px;
  }

  .tool-logo {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    flex-shrink: 0;
  }

  .tool-logo-placeholder {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xl);
    font-weight: var(--font-extrabold);
    color: white;
    flex-shrink: 0;
  }

  .card-top-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .tool-name {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--color-text-bright);
    line-height: var(--leading-snug);
    letter-spacing: -0.01em;
  }

  /* Star rating */
  .star-rating {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-base);
    line-height: 1;
  }

  .star {
    display: inline-block;
    -webkit-text-fill-color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
  }

  .star.full {
    background: var(--color-accent);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .star.empty {
    background: rgba(148, 163, 184, 0.2);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .star.partial {
    background: linear-gradient(
      90deg,
      var(--color-accent) var(--fill),
      rgba(148, 163, 184, 0.2) var(--fill)
    );
    -webkit-background-clip: text;
    background-clip: text;
  }

  .rating-value {
    margin-left: var(--space-1);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    -webkit-text-fill-color: var(--color-text-muted);
  }

  /* Summary */
  .tool-summary {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Pros / Cons */
  .pros-list,
  .cons-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex-grow: 1;
  }

  .pros-list li,
  .cons-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: var(--leading-normal);
  }

  .icon {
    flex-shrink: 0;
    font-size: var(--text-xs);
    width: 1.1rem;
    text-align: center;
    padding-top: var(--space-1);
  }

  .pro-icon {
    color: var(--color-success);
  }

  .con-icon {
    color: var(--color-error);
  }

  /* Bottom: pricing + CTA */
  .card-bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .pricing-tag {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
    line-height: var(--leading-normal);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-4);
    font-weight: var(--font-semibold);
    font-size: var(--text-sm);
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    text-decoration: none;
    transition: all var(--transition-base);
    white-space: nowrap;
  }

  .cta-btn:hover {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
    transform: translateY(-1px);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
    color: white;
  }

  .cta-btn:focus-visible {
    outline: 2px solid var(--color-border-focus);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tool-rating-card,
    .cta-btn {
      transition: none;
    }
    .tool-rating-card:hover,
    .cta-btn:hover {
      transform: none;
    }
  }
</style>
