---
import type { ToolCardData } from '../../lib/site';
import { appendUtmParams } from '../../lib/site';

interface Props {
  tool: ToolCardData;
}

const { tool } = Astro.props;
const ctaUrlWithUtm = appendUtmParams(tool.ctaUrl);

const fullStars = Math.floor(tool.rating);
const partialFill = Math.round((tool.rating - fullStars) * 100);
const emptyStars = 5 - fullStars - (partialFill > 0 ? 1 : 0);

const initial = tool.name.charAt(0).toUpperCase();
---

<div class="tool-rating-card">
  <div class="card-top">
    {tool.logo ? (
      <img src={tool.logo} alt={`${tool.name} logo`} class="tool-logo" width="64" height="64" />
    ) : (
      <div class="tool-logo-placeholder" aria-hidden="true">{initial}</div>
    )}
    <div class="card-top-info">
      <h3 class="tool-name">{tool.name}</h3>
      <div class="star-rating" aria-label={`Rating: ${tool.rating} out of 5`}>
        {Array.from({ length: fullStars }).map(() => (
          <span class="star full">&#9733;</span>
        ))}
        {partialFill > 0 && (
          <span
            class="star partial"
            style={`--fill: ${partialFill}%`}
          >&#9733;</span>
        )}
        {Array.from({ length: emptyStars }).map(() => (
          <span class="star empty">&#9733;</span>
        ))}
        <span class="rating-value">{tool.rating.toFixed(1)}</span>
      </div>
    </div>
  </div>

  <p class="tool-summary">{tool.summary}</p>

  {tool.pros.length > 0 && (
    <ul class="pros-list">
      {tool.pros.map((pro) => (
        <li><span class="icon pro-icon" aria-hidden="true">&#10003;</span>{pro}</li>
      ))}
    </ul>
  )}

  {tool.cons.length > 0 && (
    <ul class="cons-list">
      {tool.cons.map((con) => (
        <li><span class="icon con-icon" aria-hidden="true">&#10007;</span>{con}</li>
      ))}
    </ul>
  )}

  <div class="card-bottom">
    {tool.pricing && (
      <span class="pricing-tag">{tool.pricing}</span>
    )}
    <a
      href={ctaUrlWithUtm}
      class="cta-btn"
      target="_blank"
      rel="nofollow sponsored noopener"
    >
      {tool.ctaLabel}
    </a>
  </div>
</div>

<style>
  .tool-rating-card {
    background: var(--color-panel, var(--panel));
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0.75rem;
    transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
  }

  .tool-rating-card:hover {
    border-color: rgba(125, 211, 252, 0.3);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(2, 6, 23, 0.35);
  }

  .tool-rating-card:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.5);
    outline-offset: 2px;
  }

  /* Top: logo + name + stars */
  .card-top {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    min-height: 64px;
  }

  .tool-logo {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .tool-logo-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--color-primary, var(--brand-strong)), var(--color-accent, var(--accent)));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 800;
    color: white;
    flex-shrink: 0;
  }

  .card-top-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tool-name {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary, var(--text));
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  /* Star rating */
  .star-rating {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    font-size: 1rem;
    line-height: 1;
  }

  .star {
    display: inline-block;
    -webkit-text-fill-color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
  }

  .star.full {
    background: var(--color-accent, var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
  }

  .star.empty {
    background: rgba(148, 163, 184, 0.2);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .star.partial {
    background: linear-gradient(
      90deg,
      var(--color-accent, var(--accent)) var(--fill),
      rgba(148, 163, 184, 0.2) var(--fill)
    );
    -webkit-background-clip: text;
    background-clip: text;
  }

  .rating-value {
    margin-left: 0.4rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-muted, var(--muted));
    -webkit-text-fill-color: var(--color-text-muted, var(--muted));
  }

  /* Summary */
  .tool-summary {
    color: var(--color-text-secondary, var(--muted));
    font-size: 0.9rem;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Pros / Cons */
  .pros-list,
  .cons-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    flex-grow: 1;
  }

  .pros-list li,
  .cons-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text, var(--text));
    line-height: 1.5;
  }

  .icon {
    flex-shrink: 0;
    font-size: 0.8rem;
    width: 1.1rem;
    text-align: center;
    padding-top: 0.2rem;
  }

  .pro-icon {
    color: #22c55e;
  }

  .con-icon {
    color: #ef4444;
  }

  /* Bottom: pricing + CTA */
  .card-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.875rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .pricing-tag {
    font-size: 0.8rem;
    color: var(--color-text-muted, var(--muted));
    font-weight: 500;
    line-height: 1.4;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    border-radius: 8px;
    padding: 0.6rem 1.25rem;
    font-weight: 600;
    font-size: 0.875rem;
    background: linear-gradient(135deg, var(--color-primary, #3b82f6), var(--color-primary-dark, #2563eb));
    color: white;
    text-decoration: none;
    transition: filter 150ms ease, box-shadow 150ms ease;
    white-space: nowrap;
  }

  .cta-btn:hover {
    filter: brightness(1.1);
    box-shadow: 0 4px 16px rgba(59, 130, 246, 0.3);
    color: white;
  }

  .cta-btn:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.5);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tool-rating-card,
    .cta-btn {
      transition: none;
    }
    .tool-rating-card:hover {
      transform: none;
    }
  }
</style>
