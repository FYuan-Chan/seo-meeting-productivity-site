---
import type { UseCaseItem } from '../../lib/site';

interface Props {
  useCases: UseCaseItem[];
}

const { useCases } = Astro.props;
---

<div class="usecase-grid">
  {useCases.map((item) => (
    <div class="usecase-card">
      <div class="card-icon">{item.icon || '💡'}</div>
      <h3 class="card-scenario">{item.scenario}</h3>
      <div class="card-recommended">{item.recommended}</div>
      <p class="card-reason">{item.reason}</p>
    </div>
  ))}
</div>

<style>
  .usecase-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .usecase-card {
    background: var(--color-surface, var(--panel));
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg, 12px);
    padding: 1.5rem;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .usecase-card:hover {
    border-color: rgba(125, 211, 252, 0.25);
    box-shadow: 0 2px 12px rgba(2, 6, 23, 0.25);
  }

  .card-icon {
    font-size: 1.75rem;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .card-scenario {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-primary, var(--text));
    margin: 0 0 0.5rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .card-recommended {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary-light, var(--brand));
    margin-bottom: 0.5rem;
  }

  .card-reason {
    font-size: 0.875rem;
    color: var(--color-text-muted, var(--muted));
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .usecase-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
