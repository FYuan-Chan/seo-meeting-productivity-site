---
import type { UseCaseItem } from '../../lib/site';

interface Props {
  useCases: UseCaseItem[];
}

const { useCases } = Astro.props;
---

<div class="usecase-grid">
  {useCases.map((item) => (
    <div class="usecase-card">
      <div class="card-icon">{item.icon || '💡'}</div>
      <h3 class="card-scenario">{item.scenario}</h3>
      <div class="card-recommended">{item.recommended}</div>
      <p class="card-reason">{item.reason}</p>
    </div>
  ))}
</div>

<style>
  .usecase-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .usecase-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.35rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .usecase-card:hover {
    border-color: rgba(125, 211, 252, 0.35);
    box-shadow: 0 0 20px rgba(125, 211, 252, 0.06);
  }

  .card-icon {
    font-size: 32px;
    line-height: 1;
    margin-bottom: 0.65rem;
  }

  .card-scenario {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.7rem;
    line-height: 1.3;
  }

  .card-recommended {
    font-weight: 600;
    font-size: 1rem;
    color: var(--brand);
    margin-bottom: 0.5rem;
  }

  .card-reason {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .usecase-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
