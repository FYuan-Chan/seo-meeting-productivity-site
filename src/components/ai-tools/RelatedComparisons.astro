---
import { getAllPageEntries } from '../../lib/site';

interface Props {
  relatedSlugs: string[];
  currentSlug: string;
}

const { relatedSlugs, currentSlug } = Astro.props;

const allPages = getAllPageEntries();
const relatedPages = allPages.filter(
  (page) => relatedSlugs.includes(page.slug) && page.slug !== currentSlug
);
---

{relatedPages.length > 0 && (
  <section class="related-section">
    <h2 class="related-heading">Related Comparisons</h2>
    <div class="related-grid">
      {relatedPages.map((page) => (
        <a href={`/pages/${page.slug}/`} class="related-card">
          <div class="related-card-body">
            <h3 class="related-title">{page.title}</h3>
            <p class="related-desc">
              {page.description.length > 120
                ? page.description.slice(0, 120) + '...'
                : page.description}
            </p>
          </div>
          <span class="related-arrow">→</span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-section {
    margin-top: 2.5rem;
  }

  .related-heading {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary, var(--text));
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .related-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--color-surface, rgba(19, 26, 46, 0.95));
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg, 12px);
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: var(--color-text, var(--text));
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .related-card:hover {
    border-color: rgba(59, 130, 246, 0.3);
    box-shadow: 0 2px 12px rgba(2, 6, 23, 0.25);
  }

  .related-card:hover .related-arrow {
    transform: translateX(4px);
  }

  .related-card-body {
    flex: 1;
    min-width: 0;
  }

  .related-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-primary, var(--text));
    margin: 0 0 0.35rem;
    line-height: 1.3;
  }

  .related-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted, var(--muted));
    margin: 0;
    line-height: 1.5;
  }

  .related-arrow {
    font-size: 1.2rem;
    color: var(--color-primary-light, var(--brand));
    flex-shrink: 0;
    transition: transform 150ms ease;
  }

  @media (max-width: 900px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
