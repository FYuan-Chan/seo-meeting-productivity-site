---
import { getAllPageEntries } from '../../lib/site';

interface Props {
  relatedSlugs: string[];
  currentSlug: string;
}

const { relatedSlugs, currentSlug } = Astro.props;

const allPages = getAllPageEntries();
const relatedPages = allPages.filter(
  (page) => relatedSlugs.includes(page.slug) && page.slug !== currentSlug
);
---

{relatedPages.length > 0 && (
  <section class="related-section">
    <h2 class="related-heading">Related Comparisons</h2>
    <div class="related-grid">
      {relatedPages.map((page) => (
        <a href={`/pages/${page.slug}/`} class="related-card">
          <div class="related-card-body">
            <h3 class="related-title">{page.title}</h3>
            <p class="related-desc">
              {page.description.length > 120
                ? page.description.slice(0, 120) + '...'
                : page.description}
            </p>
          </div>
          <span class="related-arrow">→</span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-section {
    margin-top: var(--space-10);
  }

  .related-heading {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--color-text-bright);
    margin-bottom: var(--space-5);
    letter-spacing: -0.02em;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .related-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-base);
  }

  .related-card:hover {
    background: var(--color-surface-hover);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-md);
  }

  .related-card:hover .related-arrow {
    transform: translateX(4px);
  }

  .related-card-body {
    flex: 1;
    min-width: 0;
  }

  .related-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-text-bright);
    margin: 0 0 var(--space-1);
    line-height: var(--leading-snug);
  }

  .related-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: var(--leading-normal);
  }

  .related-arrow {
    font-size: 1.2rem;
    color: var(--color-primary-light);
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  @media (max-width: 900px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .related-card,
    .related-arrow {
      transition: none;
    }
    .related-card:hover .related-arrow {
      transform: none;
    }
  }
</style>
