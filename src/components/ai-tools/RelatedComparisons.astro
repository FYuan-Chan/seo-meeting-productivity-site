---
import { getAllPageEntries } from '../../lib/site';

interface Props {
  relatedSlugs: string[];
  currentSlug: string;
}

const { relatedSlugs, currentSlug } = Astro.props;

const allPages = getAllPageEntries();
const relatedPages = allPages.filter(
  (page) => relatedSlugs.includes(page.slug) && page.slug !== currentSlug
);
---

{relatedPages.length > 0 && (
  <section class="related-section">
    <h2 class="related-heading">Related Comparisons</h2>
    <div class="related-grid">
      {relatedPages.map((page) => (
        <a href={`/pages/${page.slug}/`} class="related-card">
          <div class="related-card-body">
            <h3 class="related-title">{page.title}</h3>
            <p class="related-desc">
              {page.description.length > 120
                ? page.description.slice(0, 120) + '...'
                : page.description}
            </p>
          </div>
          <span class="related-arrow">→</span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-section {
    margin-top: 2rem;
  }

  .related-heading {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .related-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: linear-gradient(180deg, rgba(16, 29, 52, 0.96), rgba(11, 20, 37, 0.98));
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.35rem;
    text-decoration: none;
    color: var(--text);
    box-shadow: var(--shadow);
    transition: border-color 0.25s ease, transform 0.2s ease;
  }

  .related-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
  }

  .related-card:hover .related-arrow {
    transform: translateX(4px);
  }

  .related-card-body {
    flex: 1;
    min-width: 0;
  }

  .related-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.4rem;
    line-height: 1.3;
  }

  .related-desc {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }

  .related-arrow {
    font-size: 1.3rem;
    color: var(--brand);
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  @media (max-width: 900px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
