---
import type { PricingPlan } from '../../lib/site';

interface Props {
  plans: PricingPlan[];
}

const { plans } = Astro.props;
---

<!-- Desktop Table -->
<div class="pricing-table-wrap">
  <table class="pricing-table">
    <thead>
      <tr>
        <th>Tool</th>
        <th>Free</th>
        <th>Pro</th>
        <th>Enterprise</th>
        <th>Best For</th>
      </tr>
    </thead>
    <tbody>
      {plans.map((plan) => (
        <tr class:list={[{ highlighted: !!plan.bestFor }]}>
          <td class="tool-name">{plan.toolName}</td>
          <td>{plan.free ? plan.free : <span class="empty-cell">—</span>}</td>
          <td>{plan.pro ? plan.pro : <span class="empty-cell">—</span>}</td>
          <td>{plan.enterprise ? plan.enterprise : <span class="empty-cell">—</span>}</td>
          <td>
            {plan.bestFor ? (
              <span class="best-for-badge">{plan.bestFor}</span>
            ) : (
              <span class="empty-cell">—</span>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<!-- Mobile Cards -->
<div class="pricing-cards">
  {plans.map((plan) => (
    <div class:list={['pricing-card', { highlighted: !!plan.bestFor }]}>
      <div class="card-header">{plan.toolName}</div>
      <div class="card-row">
        <span class="card-label">Free</span>
        <span>{plan.free ? plan.free : <span class="empty-cell">—</span>}</span>
      </div>
      <div class="card-row">
        <span class="card-label">Pro</span>
        <span>{plan.pro ? plan.pro : <span class="empty-cell">—</span>}</span>
      </div>
      <div class="card-row">
        <span class="card-label">Enterprise</span>
        <span>{plan.enterprise ? plan.enterprise : <span class="empty-cell">—</span>}</span>
      </div>
      {plan.bestFor && (
        <div class="card-row">
          <span class="card-label">Best For</span>
          <span class="best-for-badge">{plan.bestFor}</span>
        </div>
      )}
    </div>
  ))}
</div>

<style>
  /* Desktop Table */
  .pricing-table-wrap {
    overflow-x: auto;
    border-radius: var(--radius-lg, 12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: var(--color-surface, var(--panel));
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
    table-layout: fixed;
  }

  .pricing-table th:nth-child(1),
  .pricing-table td:nth-child(1) { width: 14%; }
  .pricing-table th:nth-child(2),
  .pricing-table td:nth-child(2) { width: 18%; }
  .pricing-table th:nth-child(3),
  .pricing-table td:nth-child(3) { width: 22%; }
  .pricing-table th:nth-child(4),
  .pricing-table td:nth-child(4) { width: 22%; }
  .pricing-table th:nth-child(5),
  .pricing-table td:nth-child(5) { width: 24%; }

  .pricing-table thead {
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .pricing-table th {
    padding: 0.75rem 1rem;
    text-align: left;
    color: var(--color-text-primary, #f8fafc);
    background: var(--color-bg-alt, rgba(16, 24, 40, 0.95));
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .pricing-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--color-text, var(--text));
    vertical-align: middle;
    font-size: 0.9rem;
  }

  .pricing-table tbody tr {
    transition: background 100ms ease;
  }

  .pricing-table tbody tr:hover {
    background: rgba(59, 130, 246, 0.04);
  }

  .pricing-table tbody tr.highlighted {
    border-left: 3px solid var(--color-primary, var(--accent));
    background: rgba(59, 130, 246, 0.04);
  }

  .pricing-table tbody tr.highlighted:hover {
    background: rgba(59, 130, 246, 0.07);
  }

  .tool-name {
    font-weight: 600;
    color: var(--color-primary-light, var(--brand));
  }

  .empty-cell {
    color: var(--color-text-hint, var(--muted));
    opacity: 0.4;
  }

  .best-for-badge {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-secondary, #cbd5e1);
    line-height: 1.5;
    word-break: break-word;
    max-width: 100%;
  }

  /* Mobile Cards */
  .pricing-cards {
    display: none;
  }

  .pricing-card {
    background: var(--color-surface, var(--panel));
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg, 12px);
    padding: 1.25rem;
  }

  .pricing-card.highlighted {
    border-color: rgba(59, 130, 246, 0.3);
    border-left: 3px solid var(--color-primary, var(--accent));
  }

  .card-header {
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-primary-light, var(--brand));
    margin-bottom: 0.85rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .card-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    color: var(--color-text, var(--text));
    font-size: 0.9rem;
  }

  .card-row:last-child {
    border-bottom: none;
  }

  .card-label {
    color: var(--color-text-muted, var(--muted));
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (max-width: 900px) {
    .pricing-table-wrap {
      display: none;
    }
    .pricing-cards {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
  }
</style>
