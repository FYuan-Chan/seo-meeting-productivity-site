---
import type { PricingPlan } from '../../lib/site';

interface Props {
  plans: PricingPlan[];
}

const { plans } = Astro.props;
---

<!-- Desktop Table -->
<div class="pricing-table-wrap">
  <table class="pricing-table">
    <thead>
      <tr>
        <th>Tool</th>
        <th>Free</th>
        <th>Pro</th>
        <th>Enterprise</th>
        <th>Best For</th>
      </tr>
    </thead>
    <tbody>
      {plans.map((plan) => (
        <tr class:list={[{ highlighted: !!plan.bestFor }]}>
          <td class="tool-name">{plan.toolName}</td>
          <td>{plan.free ? plan.free : <span class="empty-cell">—</span>}</td>
          <td>{plan.pro ? plan.pro : <span class="empty-cell">—</span>}</td>
          <td>{plan.enterprise ? plan.enterprise : <span class="empty-cell">—</span>}</td>
          <td>
            {plan.bestFor ? (
              <span class="best-for-badge">{plan.bestFor}</span>
            ) : (
              <span class="empty-cell">—</span>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<!-- Mobile Cards -->
<div class="pricing-cards">
  {plans.map((plan) => (
    <div class:list={['pricing-card', { highlighted: !!plan.bestFor }]}>
      <div class="card-header">{plan.toolName}</div>
      <div class="card-row">
        <span class="card-label">Free</span>
        <span>{plan.free ? plan.free : <span class="empty-cell">—</span>}</span>
      </div>
      <div class="card-row">
        <span class="card-label">Pro</span>
        <span>{plan.pro ? plan.pro : <span class="empty-cell">—</span>}</span>
      </div>
      <div class="card-row">
        <span class="card-label">Enterprise</span>
        <span>{plan.enterprise ? plan.enterprise : <span class="empty-cell">—</span>}</span>
      </div>
      {plan.bestFor && (
        <div class="card-row">
          <span class="card-label">Best For</span>
          <span class="best-for-badge">{plan.bestFor}</span>
        </div>
      )}
    </div>
  ))}
</div>

<style>
  /* Desktop Table */
  .pricing-table-wrap {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
    table-layout: fixed;
  }

  .pricing-table th:nth-child(1),
  .pricing-table td:nth-child(1) { width: 14%; }
  .pricing-table th:nth-child(2),
  .pricing-table td:nth-child(2) { width: 18%; }
  .pricing-table th:nth-child(3),
  .pricing-table td:nth-child(3) { width: 22%; }
  .pricing-table th:nth-child(4),
  .pricing-table td:nth-child(4) { width: 22%; }
  .pricing-table th:nth-child(5),
  .pricing-table td:nth-child(5) { width: 24%; }

  .pricing-table thead {
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .pricing-table th {
    padding: var(--space-3) var(--space-4);
    text-align: left;
    color: var(--color-text-bright);
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .pricing-table td {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    vertical-align: middle;
    font-size: var(--text-sm);
  }

  .pricing-table tbody tr {
    transition: background var(--transition-fast);
  }

  .pricing-table tbody tr:hover {
    background: rgba(59, 130, 246, 0.04);
  }

  .pricing-table tbody tr.highlighted {
    border-left: 3px solid var(--color-primary);
    background: rgba(59, 130, 246, 0.04);
  }

  .pricing-table tbody tr.highlighted:hover {
    background: rgba(59, 130, 246, 0.07);
  }

  .tool-name {
    font-weight: var(--font-semibold);
    color: var(--color-primary-light);
  }

  .empty-cell {
    color: var(--color-text-dim);
    opacity: 0.6;
  }

  .best-for-badge {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    word-break: break-word;
    max-width: 100%;
  }

  /* Mobile Cards */
  .pricing-cards {
    display: none;
  }

  .pricing-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }

  .pricing-card.highlighted {
    border-color: rgba(59, 130, 246, 0.3);
    border-left: 3px solid var(--color-primary);
  }

  .card-header {
    font-weight: var(--font-semibold);
    font-size: var(--text-lg);
    color: var(--color-primary-light);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .card-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .card-row:last-child {
    border-bottom: none;
  }

  .card-label {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (max-width: 900px) {
    .pricing-table-wrap {
      display: none;
    }
    .pricing-cards {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-table tbody tr {
      transition: none;
    }
  }
</style>
