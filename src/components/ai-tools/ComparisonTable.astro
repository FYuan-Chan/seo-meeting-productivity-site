---
interface Props {
  dimensions: string[];
  tools: string[];
  ratings: Record<string, Record<string, number | string>>;
}

const { dimensions = [], tools = [], ratings = {} } = Astro.props;

function getRatingColor(value: number): string {
  if (value >= 9) return 'var(--color-primary)';
  if (value >= 7) return 'var(--color-success)';
  if (value >= 4) return 'var(--color-warning)';
  return 'var(--color-error)';
}

function getRatingValue(dim: string, tool: string): number | string | undefined {
  const toolRatings = ratings[tool];
  if (!toolRatings) return undefined;
  return toolRatings[dim];
}

function isNumeric(val: number | string | undefined): val is number {
  return typeof val === 'number';
}
---

<!-- Desktop table view -->
<div class="comparison-wrapper desktop-view">
  <div class="comparison-table-outer">
    <table class="comparison-table">
      <thead>
        <tr>
          <th class="dim-header">Dimension</th>
          {tools.map((tool) => (
            <th>{tool}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {dimensions.map((dim) => (
          <tr>
            <td class="dim-cell">{dim}</td>
            {tools.map((tool) => {
              const val = getRatingValue(dim, tool);
              return (
                <td>
                  {isNumeric(val) ? (
                    <div class="rating-bar-wrap">
                      <div
                        class="rating-bar"
                        style={`width: ${(val / 10) * 100}%; background: ${getRatingColor(val)};`}
                      />
                      <span class="rating-num">{val}</span>
                    </div>
                  ) : (
                    <span class="rating-text">{val ?? '—'}</span>
                  )}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<!-- Mobile card view -->
<div class="comparison-wrapper mobile-view">
  {tools.map((tool) => (
    <div class="tool-card-mobile">
      <h4 class="tool-card-mobile-name">{tool}</h4>
      <ul class="tool-card-mobile-list">
        {dimensions.map((dim) => {
          const val = getRatingValue(dim, tool);
          return (
            <li>
              <span class="dim-label">{dim}</span>
              {isNumeric(val) ? (
                <div class="rating-bar-wrap">
                  <div
                    class="rating-bar"
                    style={`width: ${(val / 10) * 100}%; background: ${getRatingColor(val)};`}
                  />
                  <span class="rating-num">{val}</span>
                </div>
              ) : (
                <span class="rating-text">{val ?? '—'}</span>
              )}
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</div>

<style>
  /* Outer wrapper */
  .comparison-wrapper.mobile-view {
    display: none;
  }

  /* Desktop table */
  .comparison-table-outer {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 600px;
  }

  .comparison-table thead tr {
    background: var(--color-bg-alt);
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .comparison-table th,
  .comparison-table td {
    padding: var(--space-3) var(--space-4);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .comparison-table th {
    font-weight: var(--font-semibold);
    white-space: nowrap;
    color: var(--color-text-bright);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .dim-header,
  .dim-cell {
    position: sticky;
    left: 0;
    z-index: 1;
    background: var(--color-surface);
    min-width: 160px;
    font-weight: var(--font-semibold);
  }

  .dim-header {
    background: var(--color-bg-alt);
    z-index: 3;
  }

  .comparison-table tbody tr {
    transition: background var(--transition-fast);
  }

  .comparison-table tbody tr:hover td {
    background: rgba(59, 130, 246, 0.04);
  }

  .comparison-table tbody tr:hover .dim-cell {
    background: var(--color-surface);
  }

  /* Rating bar */
  .rating-bar-wrap {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 120px;
  }

  .rating-bar {
    height: 6px;
    border-radius: 3px;
    flex-shrink: 0;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.2);
    transition: width var(--transition-slow);
  }

  .rating-bar-wrap .rating-bar {
    flex: 0 0 auto;
    max-width: calc(100% - 2.5rem);
  }

  .rating-num {
    font-weight: var(--font-bold);
    font-size: var(--text-sm);
    font-variant-numeric: tabular-nums;
    color: var(--color-text);
    flex-shrink: 0;
  }

  .rating-text {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  /* Mobile card view */
  @media (max-width: 900px) {
    .comparison-wrapper.desktop-view {
      display: none;
    }

    .comparison-wrapper.mobile-view {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .tool-card-mobile {
      background: var(--color-card);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
    }

    .tool-card-mobile-name {
      margin: 0 0 var(--space-4);
      font-size: var(--text-lg);
      font-weight: var(--font-bold);
      color: var(--color-text-bright);
    }

    .tool-card-mobile-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .tool-card-mobile-list li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-4);
      padding: var(--space-2) 0;
      border-top: 1px solid var(--color-border);
    }

    .dim-label {
      color: var(--color-text-muted);
      font-size: var(--text-sm);
      flex-shrink: 0;
    }

    .rating-bar-wrap {
      min-width: 100px;
      max-width: 160px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .comparison-table tbody tr,
    .rating-bar {
      transition: none;
    }
  }
</style>
