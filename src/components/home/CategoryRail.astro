---
import type { PageCategory, SeoPage } from '../../lib/site';
import ArticleCard from '../cards/ArticleCard.astro';
import { categoryHasArchive, categoryLabel } from '../../lib/articles';

interface Props {
  category: PageCategory;
  title: string;
  description: string;
  items: SeoPage[];
  limit?: number;
}

const { category, title, description, items, limit = 3 } = Astro.props;
const shown = items.slice(0, limit);
const hasArchive = categoryHasArchive(category);
---

<section class="rail" aria-labelledby={`rail-${category}-heading`}>
  <div class="container">
    <header class="rail-header">
      <div>
        <p class="eyebrow-caps">{categoryLabel(category)}</p>
        <h2 id={`rail-${category}-heading`} class="headline-2">{title}</h2>
        <p class="rail-dek">{description}</p>
      </div>
      {hasArchive && (
        <a class="rail-cta" href={`/category/${category}/`}>
          More in {categoryLabel(category)} →
        </a>
      )}
    </header>
    <div class="rail-grid">
      {shown.map((page) => <ArticleCard page={page} variant="compact" />)}
    </div>
  </div>
</section>

<style>
  .rail {
    padding: var(--space-12) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .rail-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }
  .rail-dek {
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--text-base);
    max-width: 56ch;
  }
  .rail-cta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary-light);
    text-decoration: none;
    white-space: nowrap;
  }
  .rail-cta:hover { color: var(--color-primary); }
  .rail-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }
  @media (max-width: 900px) {
    .rail-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .rail-header { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 600px) {
    .rail-grid { grid-template-columns: 1fr; }
  }
</style>
