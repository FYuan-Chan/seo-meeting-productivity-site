---
// JSON Formatter Tool Component
interface Props {
  title?: string;
}

const { title = 'JSON Formatter & Validator' } = Astro.props;
---

<div class="tool-container json-formatter">
  <div class="tool-header">
    <h3>{title}</h3>
    <p class="tool-description">Paste your JSON below to format, validate, and beautify it instantly.</p>
  </div>
  
  <div class="tool-body">
    <div class="input-section">
      <label for="json-input">Input JSON</label>
      <textarea 
        id="json-input" 
        placeholder='{"name": "example", "value": 123}'
        rows="8"
      ></textarea>
    </div>
    
    <div class="controls">
      <button id="format-btn" class="btn primary">Format & Validate</button>
      <button id="minify-btn" class="btn secondary">Minify</button>
      <button id="copy-btn" class="btn secondary">Copy Output</button>
      <button id="clear-btn" class="btn outline">Clear</button>
    </div>
    
    <div class="output-section">
      <label for="json-output">Formatted Output</label>
      <textarea 
        id="json-output" 
        readonly
        rows="8"
        placeholder="Formatted JSON will appear here..."
      ></textarea>
      <div id="error-message" class="error-message"></div>
    </div>
    
    <div class="stats">
      <span id="stat-lines">Lines: 0</span>
      <span id="stat-size">Size: 0 bytes</span>
      <span id="stat-valid" class="valid">✓ Valid JSON</span>
    </div>
  </div>
</div>

<style>
  .tool-container {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
    border: 1px solid #3a3a5a;
  }
  
  .tool-header {
    margin-bottom: 1.5rem;
  }
  
  .tool-header h3 {
    color: #fff;
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }
  
  .tool-description {
    color: #a0a0c0;
    margin: 0;
    font-size: 0.95rem;
  }
  
  .tool-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  label {
    display: block;
    color: #c0c0e0;
    font-weight: 500;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }
  
  textarea {
    width: 100%;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid #3a3a5a;
    background: #0d0d1a;
    color: #e0e0ff;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 0.9rem;
    resize: vertical;
    box-sizing: border-box;
  }
  
  textarea:focus {
    outline: none;
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
  }
  
  textarea[readonly] {
    background: #0a0a15;
    cursor: default;
  }
  
  .controls {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  
  .btn {
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    font-size: 0.9rem;
  }
  
  .btn.primary {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
  }
  
  .btn.primary:hover {
    background: linear-gradient(135deg, #5558e6 0%, #7c4fec 100%);
    transform: translateY(-1px);
  }
  
  .btn.secondary {
    background: #2a2a4a;
    color: #c0c0e0;
    border: 1px solid #3a3a5a;
  }
  
  .btn.secondary:hover {
    background: #3a3a5a;
  }
  
  .btn.outline {
    background: transparent;
    color: #a0a0c0;
    border: 1px solid #3a3a5a;
  }
  
  .btn.outline:hover {
    background: #1a1a2e;
    color: #fff;
  }
  
  .error-message {
    color: #ef4444;
    font-size: 0.85rem;
    margin-top: 0.5rem;
    min-height: 1.2rem;
  }
  
  .stats {
    display: flex;
    gap: 1.5rem;
    color: #8080a0;
    font-size: 0.85rem;
    padding-top: 0.5rem;
    border-top: 1px solid #2a2a4a;
  }
  
  .stats .valid {
    color: #22c55e;
  }
  
  .stats .invalid {
    color: #ef4444;
  }
</style>

<script>
  function initJsonFormatter() {
    const input = document.getElementById('json-input') as HTMLTextAreaElement;
    const output = document.getElementById('json-output') as HTMLTextAreaElement;
    const formatBtn = document.getElementById('format-btn');
    const minifyBtn = document.getElementById('minify-btn');
    const copyBtn = document.getElementById('copy-btn');
    const clearBtn = document.getElementById('clear-btn');
    const errorMessage = document.getElementById('error-message');
    const statLines = document.getElementById('stat-lines');
    const statSize = document.getElementById('stat-size');
    const statValid = document.getElementById('stat-valid');
    
    if (!input || !output) return;
    
    function updateStats(jsonString: string, isValid: boolean) {
      const lines = jsonString ? jsonString.split('\n').length : 0;
      const size = new Blob([jsonString]).size;
      
      if (statLines) statLines.textContent = `Lines: ${lines}`;
      if (statSize) statSize.textContent = `Size: ${size} bytes`;
      
      if (statValid) {
        statValid.textContent = isValid ? '✓ Valid JSON' : '✗ Invalid JSON';
        statValid.className = isValid ? 'valid' : 'invalid';
      }
    }
    
    function formatJSON() {
      try {
        const parsed = JSON.parse(input.value);
        const formatted = JSON.stringify(parsed, null, 2);
        output.value = formatted;
        if (errorMessage) errorMessage.textContent = '';
        updateStats(formatted, true);
      } catch (e: any) {
        if (errorMessage) errorMessage.textContent = `Error: ${e.message}`;
        output.value = '';
        updateStats('', false);
      }
    }
    
    function minifyJSON() {
      try {
        const parsed = JSON.parse(input.value);
        const minified = JSON.stringify(parsed);
        output.value = minified;
        if (errorMessage) errorMessage.textContent = '';
        updateStats(minified, true);
      } catch (e: any) {
        if (errorMessage) errorMessage.textContent = `Error: ${e.message}`;
        output.value = '';
        updateStats('', false);
      }
    }
    
    function copyOutput() {
      if (output.value) {
        navigator.clipboard.writeText(output.value);
        if (copyBtn) {
          const originalText = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          setTimeout(() => {
            copyBtn.textContent = originalText;
          }, 1500);
        }
      }
    }
    
    function clearAll() {
      input.value = '';
      output.value = '';
      if (errorMessage) errorMessage.textContent = '';
      updateStats('', true);
    }
    
    formatBtn?.addEventListener('click', formatJSON);
    minifyBtn?.addEventListener('click', minifyJSON);
    copyBtn?.addEventListener('click', copyOutput);
    clearBtn?.addEventListener('click', clearAll);
    
    // Real-time validation on input
    input.addEventListener('input', () => {
      try {
        JSON.parse(input.value);
        if (errorMessage) errorMessage.textContent = '';
        updateStats(input.value, true);
      } catch (e: any) {
        if (input.value.trim()) {
          if (errorMessage) errorMessage.textContent = `Invalid: ${e.message}`;
        } else {
          if (errorMessage) errorMessage.textContent = '';
        }
        updateStats(input.value, false);
      }
    });
  }
  
  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initJsonFormatter);
  } else {
    initJsonFormatter();
  }
</script>
