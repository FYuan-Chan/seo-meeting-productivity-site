---
// Password Generator Tool Component
interface Props {
  title?: string;
}

const { title = 'Password Generator' } = Astro.props;
---

<div class="tool-container password-generator">
  <div class="tool-header">
    <h3>{title}</h3>
    <p class="tool-description">Generate secure, random passwords with customizable options.</p>
  </div>
  
  <div class="tool-body">
    <div class="output-section">
      <label>Generated Password</label>
      <div class="password-display">
        <input 
          type="text" 
          id="password-output" 
          readonly
          placeholder="Click Generate to create a password"
        />
        <button id="copy-password-btn" class="icon-btn" title="Copy">📋</button>
        <button id="refresh-btn" class="icon-btn" title="Regenerate">🔄</button>
      </div>
      <div class="strength-meter">
        <div id="strength-bar" class="strength-bar"></div>
        <span id="strength-label" class="strength-label">--</span>
      </div>
    </div>
    
    <div class="options-section">
      <h4>Password Options</h4>
      
      <div class="option-row">
        <label for="password-length">Length: <span id="length-value">16</span></label>
        <input 
          type="range" 
          id="password-length" 
          min="8" 
          max="64" 
          value="16"
        />
      </div>
      
      <div class="option-row">
        <label>
          <input type="checkbox" id="use-uppercase" checked />
          <span>Uppercase (A-Z)</span>
        </label>
      </div>
      
      <div class="option-row">
        <label>
          <input type="checkbox" id="use-lowercase" checked />
          <span>Lowercase (a-z)</span>
        </label>
      </div>
      
      <div class="option-row">
        <label>
          <input type="checkbox" id="use-numbers" checked />
          <span>Numbers (0-9)</span>
        </label>
      </div>
      
      <div class="option-row">
        <label>
          <input type="checkbox" id="use-symbols" checked />
          <span>Symbols (!@#$%^&*)</span>
        </label>
      </div>
      
      <div class="option-row">
        <label>
          <input type="checkbox" id="exclude-ambiguous" />
          <span>Exclude ambiguous (0O, 1lI)</span>
        </label>
      </div>
    </div>
    
    <div class="controls">
      <button id="generate-btn" class="btn primary">Generate Password</button>
      <button id="generate-5-btn" class="btn secondary">Generate 5 Passwords</button>
    </div>
    
    <div id="multiple-passwords" class="multiple-passwords hidden">
      <h4>Generated Passwords</h4>
      <div id="password-list" class="password-list"></div>
    </div>
  </div>
</div>

<style>
  .tool-container {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
    border: 1px solid #3a3a5a;
  }
  
  .tool-header {
    margin-bottom: 1.5rem;
  }
  
  .tool-header h3 {
    color: #fff;
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }
  
  .tool-description {
    color: #a0a0c0;
    margin: 0;
    font-size: 0.95rem;
  }
  
  .tool-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  label {
    color: #c0c0e0;
    font-weight: 500;
    font-size: 0.9rem;
    display: block;
    margin-bottom: 0.5rem;
  }
  
  .output-section {
    background: #0d0d1a;
    border-radius: 8px;
    padding: 1rem;
    border: 1px solid #2a2a4a;
  }
  
  .password-display {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  
  .password-display input {
    flex: 1;
    padding: 0.75rem;
    border-radius: 6px;
    border: 1px solid #3a3a5a;
    background: #1a1a2e;
    color: #e0e0ff;
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 1.1rem;
    letter-spacing: 1px;
  }
  
  .icon-btn {
    padding: 0.75rem;
    border-radius: 6px;
    border: 1px solid #3a3a5a;
    background: #2a2a4a;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.2s ease;
  }
  
  .icon-btn:hover {
    background: #3a3a5a;
  }
  
  .strength-meter {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .strength-bar {
    flex: 1;
    height: 6px;
    background: #2a2a4a;
    border-radius: 3px;
    overflow: hidden;
  }
  
  .strength-bar::after {
    content: '';
    display: block;
    height: 100%;
    width: 0;
    background: #ef4444;
    transition: width 0.3s ease, background 0.3s ease;
  }
  
  .strength-bar.weak::after {
    width: 25%;
    background: #ef4444;
  }
  
  .strength-bar.fair::after {
    width: 50%;
    background: #f59e0b;
  }
  
  .strength-bar.good::after {
    width: 75%;
    background: #22c55e;
  }
  
  .strength-bar.strong::after {
    width: 100%;
    background: #10b981;
  }
  
  .strength-label {
    font-size: 0.85rem;
    color: #8080a0;
    min-width: 60px;
  }
  
  .options-section {
    background: #0d0d1a;
    border-radius: 8px;
    padding: 1rem;
    border: 1px solid #2a2a4a;
  }
  
  .options-section h4 {
    color: #c0c0e0;
    margin: 0 0 1rem 0;
    font-size: 1rem;
  }
  
  .option-row {
    margin-bottom: 0.75rem;
  }
  
  .option-row:last-child {
    margin-bottom: 0;
  }
  
  .option-row label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0;
    cursor: pointer;
  }
  
  .option-row input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: #6366f1;
  }
  
  .option-row input[type="range"] {
    width: 100%;
    height: 6px;
    background: #2a2a4a;
    border-radius: 3px;
    outline: none;
    -webkit-appearance: none;
  }
  
  .option-row input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    background: #6366f1;
    border-radius: 50%;
    cursor: pointer;
  }
  
  .controls {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  
  .btn {
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    font-size: 0.9rem;
  }
  
  .btn.primary {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
  }
  
  .btn.primary:hover {
    background: linear-gradient(135deg, #5558e6 0%, #7c4fec 100%);
    transform: translateY(-1px);
  }
  
  .btn.secondary {
    background: #2a2a4a;
    color: #c0c0e0;
    border: 1px solid #3a3a5a;
  }
  
  .btn.secondary:hover {
    background: #3a3a5a;
  }
  
  .multiple-passwords {
    background: #0d0d1a;
    border-radius: 8px;
    padding: 1rem;
    border: 1px solid #2a2a4a;
  }
  
  .multiple-passwords h4 {
    color: #c0c0e0;
    margin: 0 0 0.75rem 0;
    font-size: 1rem;
  }
  
  .password-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .password-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: #1a1a2e;
    border-radius: 4px;
    border: 1px solid #2a2a4a;
  }
  
  .password-item code {
    font-family: 'Monaco', 'Menlo', monospace;
    color: #e0e0ff;
    font-size: 0.9rem;
  }
  
  .password-item button {
    padding: 0.25rem 0.5rem;
    background: #2a2a4a;
    border: 1px solid #3a3a5a;
    border-radius: 4px;
    color: #c0c0e0;
    cursor: pointer;
    font-size: 0.8rem;
  }
  
  .password-item button:hover {
    background: #3a3a5a;
  }
  
  .hidden {
    display: none;
  }
</style>

<script>
  function initPasswordGenerator() {
    const passwordOutput = document.getElementById('password-output') as HTMLInputElement;
    const copyBtn = document.getElementById('copy-password-btn');
    const refreshBtn = document.getElementById('refresh-btn');
    const generateBtn = document.getElementById('generate-btn');
    const generate5Btn = document.getElementById('generate-5-btn');
    const lengthSlider = document.getElementById('password-length') as HTMLInputElement;
    const lengthValue = document.getElementById('length-value');
    const strengthBar = document.getElementById('strength-bar');
    const strengthLabel = document.getElementById('strength-label');
    const multiplePasswords = document.getElementById('multiple-passwords');
    const passwordList = document.getElementById('password-list');
    
    const uppercase = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const lowercase = 'abcdefghijklmnopqrstuvwxyz';
    const numbers = '0123456789';
    const symbols = '!@#$%^&*()_+-=[]{}|;:,.<>?';
    const ambiguous = '0O1lI';
    
    function getCharSet(): string {
      let chars = '';
      
      const useUppercase = (document.getElementById('use-uppercase') as HTMLInputElement)?.checked;
      const useLowercase = (document.getElementById('use-lowercase') as HTMLInputElement)?.checked;
      const useNumbers = (document.getElementById('use-numbers') as HTMLInputElement)?.checked;
      const useSymbols = (document.getElementById('use-symbols') as HTMLInputElement)?.checked;
      const excludeAmbiguous = (document.getElementById('exclude-ambiguous') as HTMLInputElement)?.checked;
      
      if (useUppercase) chars += uppercase;
      if (useLowercase) chars += lowercase;
      if (useNumbers) chars += numbers;
      if (useSymbols) chars += symbols;
      
      if (chars.length === 0) {
        chars = lowercase + numbers;
      }
      
      if (excludeAmbiguous) {
        chars = chars.split('').filter(c => !ambiguous.includes(c)).join('');
      }
      
      return chars;
    }
    
    function generatePassword(length: number = 16): string {
      const chars = getCharSet();
      let password = '';
      
      // Use crypto API for better randomness
      const array = new Uint32Array(length);
      crypto.getRandomValues(array);
      
      for (let i = 0; i < length; i++) {
        password += chars[array[i] % chars.length];
      }
      
      return password;
    }
    
    function checkStrength(password: string): { level: string; label: string } {
      let score = 0;
      
      if (password.length >= 12) score++;
      if (password.length >= 16) score++;
      if (/[a-z]/.test(password) && /[A-Z]/.test(password)) score++;
      if (/\d/.test(password)) score++;
      if (/[^a-zA-Z0-9]/.test(password)) score++;
      
      if (score <= 2) return { level: 'weak', label: 'Weak' };
      if (score === 3) return { level: 'fair', label: 'Fair' };
      if (score === 4) return { level: 'good', label: 'Good' };
      return { level: 'strong', label: 'Strong' };
    }
    
    function updateStrength(password: string) {
      const { level, label } = checkStrength(password);
      
      if (strengthBar) {
        strengthBar.className = 'strength-bar ' + level;
      }
      if (strengthLabel) {
        strengthLabel.textContent = label;
      }
    }
    
    function updatePassword() {
      const length = parseInt(lengthSlider?.value || '16');
      const password = generatePassword(length);
      
      if (passwordOutput) {
        passwordOutput.value = password;
        updateStrength(password);
      }
      
      // Hide multiple passwords
      if (multiplePasswords) {
        multiplePasswords.classList.add('hidden');
      }
    }
    
    function generateMultiple(count: number) {
      const length = parseInt(lengthSlider?.value || '16');
      
      if (passwordList) {
        passwordList.innerHTML = '';
        
        for (let i = 0; i < count; i++) {
          const password = generatePassword(length);
          const item = document.createElement('div');
          item.className = 'password-item';
          item.innerHTML = `
            <code>${password}</code>
            <button onclick="navigator.clipboard.writeText('${password}'); this.textContent='Copied!'">Copy</button>
          `;
          passwordList.appendChild(item);
        }
      }
      
      if (multiplePasswords) {
        multiplePasswords.classList.remove('hidden');
      }
    }
    
    function copyPassword() {
      if (passwordOutput?.value) {
        navigator.clipboard.writeText(passwordOutput.value);
        if (copyBtn) {
          const original = copyBtn.textContent;
          copyBtn.textContent = '✓';
          setTimeout(() => {
            copyBtn.textContent = original;
          }, 1500);
        }
      }
    }
    
    // Event listeners
    generateBtn?.addEventListener('click', updatePassword);
    refreshBtn?.addEventListener('click', updatePassword);
    copyBtn?.addEventListener('click', copyPassword);
    generate5Btn?.addEventListener('click', () => generateMultiple(5));
    
    lengthSlider?.addEventListener('input', () => {
      if (lengthValue) {
        lengthValue.textContent = lengthSlider.value;
      }
    });
    
    // Generate initial password
    updatePassword();
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPasswordGenerator);
  } else {
    initPasswordGenerator();
  }
</script>
