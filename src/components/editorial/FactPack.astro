---
import type { EditorialFact } from '../../lib/editorial-quality';

interface Props {
  facts: EditorialFact[];
  methodology: string[];
}

const { facts, methodology } = Astro.props;
---

<section class="fact-pack" aria-labelledby="fact-pack-heading">
  <div>
    <div class="section-kicker">Fact Pack</div>
    <h2 id="fact-pack-heading">What This Article Actually Claims</h2>
  </div>

  <div class="fact-grid">
    {facts.map((fact) => (
      <article class="fact-item">
        <div class="fact-confidence">{fact.confidence} confidence</div>
        <h3>{fact.claim}</h3>
        <p>{fact.evidence}</p>
      </article>
    ))}
  </div>

  <div class="methodology">
    <h3>Methodology</h3>
    <ol>
      {methodology.map((item) => <li>{item}</li>)}
    </ol>
  </div>
</section>

<style>
  .fact-pack {
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
    padding-top: var(--space-7);
  }

  .section-kicker {
    color: #c4b5fd;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-2);
    text-transform: uppercase;
  }

  .fact-pack h2 {
    color: var(--color-text-bright);
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-5);
  }

  .fact-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .fact-item {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }

  .fact-confidence {
    color: #c4b5fd;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-3);
    text-transform: uppercase;
  }

  .fact-item h3 {
    color: var(--color-text-bright);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-3);
  }

  .fact-item p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .methodology {
    background: rgba(15, 23, 42, 0.42);
    border-left: 3px solid #c4b5fd;
    margin-top: var(--space-5);
    padding: var(--space-5);
  }

  .methodology h3 {
    color: var(--color-text-bright);
    font-size: var(--text-base);
    margin: 0 0 var(--space-3);
  }

  .methodology ol {
    color: var(--color-text);
    display: grid;
    gap: var(--space-2);
    line-height: var(--leading-normal);
    margin: 0;
    padding-left: var(--space-5);
  }

  .methodology li::marker {
    color: #c4b5fd;
    font-weight: var(--font-semibold);
  }

  @media (max-width: 900px) {
    .fact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
