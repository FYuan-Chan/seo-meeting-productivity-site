---
import type { EditorialQualityProfile } from '../../lib/editorial-quality';

interface Props {
  profile: EditorialQualityProfile;
}

const { profile } = Astro.props;
---

<aside class="review-disclosure" aria-label="Editorial review notes">
  <div>
    <p class="review-label">Editorial review</p>
    <h2>Evidence and Method</h2>
    <p>
      This page is part of the SignalForges AdSense recovery review set. It is kept in the public
      sitemap because it meets the current depth and editorial-value gate.
    </p>
  </div>

  <div class="review-grid">
    <section>
      <h3>Source Basis</h3>
      <ul>
        {profile.sourceBasis.map((item) => <li>{item}</li>)}
      </ul>
    </section>
    <section>
      <h3>Original Value</h3>
      <ul>
        {profile.originalValue.map((item) => <li>{item}</li>)}
      </ul>
    </section>
    <section>
      <h3>Visual Structure</h3>
      <ul>
        {profile.visualAssets.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  </div>
</aside>

<style>
  .review-disclosure {
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.28);
    border-radius: var(--radius-lg);
    margin: var(--space-7) 0 var(--space-8);
    padding: var(--space-5);
  }

  .review-label {
    color: #5eead4;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    margin: 0 0 var(--space-2);
    text-transform: uppercase;
  }

  .review-disclosure h2 {
    color: var(--color-text-bright);
    font-size: var(--text-xl);
    margin: 0 0 var(--space-3);
  }

  .review-disclosure p {
    color: var(--color-text);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-5);
  }

  .review-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .review-grid section {
    border-top: 1px solid rgba(20, 184, 166, 0.25);
    padding-top: var(--space-4);
  }

  .review-grid h3 {
    color: var(--color-text-bright);
    font-size: var(--text-sm);
    margin: 0 0 var(--space-3);
  }

  .review-grid ul {
    display: grid;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .review-grid li {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    padding-left: var(--space-4);
    position: relative;
  }

  .review-grid li::before {
    background: #5eead4;
    border-radius: 999px;
    content: '';
    height: 6px;
    left: 0;
    position: absolute;
    top: 0.55em;
    width: 6px;
  }

  @media (max-width: 900px) {
    .review-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
